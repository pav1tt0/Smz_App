                                        <DataTemplate>
                                            <Border Margin="0,0,0,10"
                                                    Padding="14"
                                                    Background="#F2F5F0"
                                                    CornerRadius="16">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Nominativo}"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               Foreground="#17313E" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Text="{Binding PerIdOriginaleLabel}"
                                                               Foreground="#53646A" />
                                                    <TextBlock Margin="0,2,0,0"
                                                               Text="{Binding CodiceFiscale}"
                                                               Foreground="#53646A" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Text="{Binding DataArchiviazioneLabel}"
