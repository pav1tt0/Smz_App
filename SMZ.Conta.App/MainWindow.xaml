                                                                 MaxLength="10"
                                                                 ToolTip="Digita 18032026 oppure 18/03/2026"
                                                                 infra:DateInputBehavior.AutoFormat="True" />

                                                        <TextBlock Margin="0,10,0,0" Text="Data scadenza" Foreground="#50626A" />
                                                        <TextBox Text="{Binding AbilitazioneDataScadenza, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource DateTextBoxStyle}"
                                                                 MaxLength="10"
                                                                 ToolTip="Digita 18032026 oppure 18/03/2026"
                                                                 infra:DateInputBehavior.AutoFormat="True"
                                                                 IsEnabled="{Binding AbilitazioneRichiedeScadenza}" />

                                                        <TextBlock Margin="0,10,0,0" Text="Note" Foreground="#50626A" />
                                                        <TextBox Text="{Binding AbilitazioneNote, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Grid.Row="2" Margin="0,16,0,0">
