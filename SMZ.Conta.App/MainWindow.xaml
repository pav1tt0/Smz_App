                                                                   FontWeight="SemiBold"
                                                                   Foreground="#17313E" />

                                                        <Grid Margin="0,12,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="14" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel>
                                                                <TextBlock Text="Ora inizio" Foreground="#50626A" />
