<Window x:Class="SMZ.Conta.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:controls="clr-namespace:SMZ.Conta.App.Controls"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:infra="clr-namespace:SMZ.Conta.App.Infrastructure"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Titolo}"
        Width="1660"
        Height="960"
        MinWidth="1460"
        MinHeight="780"
        WindowState="Maximized"
        Background="#0A1628"
        FontFamily="Bahnschrift">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFCF7"/>
            <Setter Property="BorderBrush" Value="#D8E1E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#C9D5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="DateTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="150"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="ImmersionTimeTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="96"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#9BC2DA"/>
            <Setter Property="Background" Value="#FFFFFF"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="HiddenTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <ContentPresenter ContentSource="SelectedContent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#E6EDF5"/>
            <Setter Property="BorderBrush" Value="#CFDAE5"/>
            <Setter Property="Foreground" Value="#4B6175"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12,12,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#F0F5FA"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#143A63"/>
                                <Setter TargetName="TabBorder" Property="Background" Value="#FFFCF7"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#C9D8E7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TabBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="MinWidth" Value="132"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#174E78"/>
            <Setter Property="Foreground" Value="#FFFDF7"/>
            <Setter Property="BorderBrush" Value="#174E78"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.48"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}" />

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#DFE8F1"/>
            <Setter Property="BorderBrush" Value="#DFE8F1"/>
            <Setter Property="Foreground" Value="#17313E"/>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#CFA032"/>
            <Setter Property="BorderBrush" Value="#CFA032"/>
            <Setter Property="Foreground" Value="#17313E"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#8F3434"/>
            <Setter Property="BorderBrush" Value="#8F3434"/>
            <Setter Property="Foreground" Value="#FFF7F3"/>
        </Style>

        <Style x:Key="HomeCardButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#C7D5E2"/>
            <Setter Property="Foreground" Value="#0F2E47"/>
            <Setter Property="MinWidth" Value="240"/>
            <Setter Property="MinHeight" Value="128"/>
            <Setter Property="Padding" Value="22,18"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="CardBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1.2"
                                    CornerRadius="26"
                                    SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="24"
                                                      ShadowDepth="8"
                                                      Direction="270"
                                                      Opacity="0.18"
                                                      Color="#15314A" />
                                </Border.Effect>
                            </Border>

                            <Border x:Name="AccentBar"
                                    Height="8"
                                    Margin="18,16,18,0"
                                    VerticalAlignment="Top"
                                    Background="{TemplateBinding BorderBrush}"
                                    CornerRadius="999" />

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#8EA9BE" />
                                <Setter TargetName="CardBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="30"
                                                          ShadowDepth="12"
                                                          Direction="270"
                                                          Opacity="0.28"
                                                          Color="#173A57" />
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="-4" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="-1" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CardBorder" Property="Opacity" Value="0.55" />
                                <Setter TargetName="AccentBar" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HomeMiniCardButtonStyle" TargetType="Button" BasedOn="{StaticResource HomeCardButtonStyle}">
            <Setter Property="MinWidth" Value="220"/>
            <Setter Property="MinHeight" Value="120"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <Style x:Key="HomeSectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4F73A5"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="HomeDarkPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="#0F2040"/>
            <Setter Property="BorderBrush" Value="#1E3860"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="HeaderHomeButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="#F5FAFF"/>
            <Setter Property="BorderBrush" Value="#7FA8DA"/>
            <Setter Property="Foreground" Value="#10274B"/>
            <Setter Property="MinWidth" Value="118"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsHomeSection}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WelcomeEnterButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F2D37B" Offset="0" />
                        <GradientStop Color="#C7962B" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#E1B24C"/>
            <Setter Property="Foreground" Value="#13293F"/>
            <Setter Property="MinWidth" Value="220"/>
            <Setter Property="MinHeight" Value="58"/>
            <Setter Property="Padding" Value="24,16"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="WelcomeMetaTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A8C2DF"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="WelcomeFeatureChipStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="BorderBrush" Value="#3E688B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#160F2237"/>
        </Style>

        <Style x:Key="WelcomeHudCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="28"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BorderBrush" Value="#3F6587"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#1A0D1D30"/>
        </Style>

        <Style x:Key="WelcomeHudLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7FA8DA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="WelcomeHudValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F7FAFD"/>
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="WelcomeAudioButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#1D2740"/>
            <Setter Property="Foreground" Value="#EAF3FB"/>
            <Setter Property="BorderBrush" Value="#4E7090"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsWelcomeAudioEnabled}" Value="True">
                    <Setter Property="Background" Value="#264B65"/>
                    <Setter Property="BorderBrush" Value="#79BCD9"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsWelcomeAudioEnabled}" Value="False">
                    <Setter Property="Background" Value="#202735"/>
                    <Setter Property="BorderBrush" Value="#4D5C73"/>
                    <Setter Property="Foreground" Value="#AFC1D3"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WelcomeMetricCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
            <Setter Property="Background" Value="#140D1F33"/>
            <Setter Property="BorderBrush" Value="#345B7B"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <ImageBrush x:Key="HomePhotoBrush"
                    ImageSource="Assets/smz.jpg"
                    Stretch="UniformToFill" />

        <LinearGradientBrush x:Key="WelcomeScreenOverlayBrush"
                             StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="#D9061120" Offset="0" />
            <GradientStop Color="#C4122943" Offset="0.36" />
            <GradientStop Color="#E4081220" Offset="1" />
        </LinearGradientBrush>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="#2A5298"
                BorderThickness="1.4"
                CornerRadius="22"
                Padding="20"
                Margin="0,0,0,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0D2040" Offset="0" />
                    <GradientStop Color="#1A3A6B" Offset="0.52" />
                    <GradientStop Color="#0D2040" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <Image Width="124"
                       Height="94"
                       Source="Assets/logo_smz.png"
                       Stretch="Uniform"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="POLIZIA DI STATO"
                            FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="#D7E5F7"
                               HorizontalAlignment="Center" />
                    <TextBlock Margin="0,4,0,0"
                               Text="NUCLEO SOMMOZZATORI"
                               FontSize="21"
                               Foreground="#7FA8DA"
                               HorizontalAlignment="Center" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Gestione operativa di servizi giornalieri, personale e contabilita"
                               FontSize="13"
                               Foreground="#5F8CCC"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <Grid Grid.Column="2" Margin="24,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="← Home"
                                Command="{Binding NavigateSectionCommand}"
                                CommandParameter="0"
                                ToolTip="Torna alla schermata iniziale"
                                Style="{StaticResource HeaderHomeButtonStyle}" />
                    </StackPanel>

                    <Border Grid.Row="2"
                            Height="94"
                            CornerRadius="18"
                            BorderBrush="#284A78"
                            BorderThickness="1.2"
                            Background="{StaticResource HomePhotoBrush}"
                            VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <TabControl SelectedIndex="{Binding SezioneAttivaIndex}"
                        Style="{StaticResource HiddenTabControlStyle}">
                <TabItem Header="Home">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="28" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="MODULI PRINCIPALI"
                                       Style="{StaticResource HomeSectionLabelStyle}" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="Accesso diretto alle aree usate ogni giorno dal nucleo."
                                       FontSize="14"
                                       Foreground="#A7C0DF" />
                        </StackPanel>

                        <Border Grid.Row="2"
                                Style="{StaticResource HomeDarkPanelStyle}"
                                Padding="22">
                            <UniformGrid Columns="5">
                                <Button Margin="0,0,18,0"
                                    Command="{Binding NavigateSectionCommand}"
                                    CommandParameter="2"
                                    Background="#F6FAFF"
                                    BorderBrush="#5B84BD"
                                    Foreground="#10274B"
                                    Style="{StaticResource HomeCardButtonStyle}">
                                    <StackPanel>
                                        <TextBlock Text="SERVIZIO"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="GIORNALIERO"
                                                   Margin="0,4,0,0"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Margin="0,0,18,0"
                                    Command="{Binding NavigateSectionCommand}"
                                    CommandParameter="3"
                                    Background="#F8FBFD"
                                    BorderBrush="#7A94AC"
                                    Foreground="#10274B"
                                    Style="{StaticResource HomeCardButtonStyle}">
                                    <StackPanel>
                                        <TextBlock Text="ANAGRAFICA"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="PERSONALE"
                                                   Margin="0,4,0,0"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Margin="0,0,18,0"
                                    Command="{Binding NavigateSectionCommand}"
                                    CommandParameter="5"
                                    Background="#F4FAFF"
                                    BorderBrush="#3E7AA6"
                                    Foreground="#10274B"
                                    Style="{StaticResource HomeCardButtonStyle}">
                                    <StackPanel>
                                        <TextBlock Text="CONTABILITA'"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Margin="0,0,18,0"
                                    Command="{Binding NavigateSectionCommand}"
                                    CommandParameter="6"
                                    Background="#FBF8F1"
                                    BorderBrush="#A77D3E"
                                    Foreground="#10274B"
                                    Style="{StaticResource HomeCardButtonStyle}">
                                    <StackPanel>
                                        <TextBlock Text="STAMPE"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="E REPORT"
                                                   Margin="0,4,0,0"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding NavigateSectionCommand}"
                                    CommandParameter="4"
                                    Background="#F7FBF8"
                                    BorderBrush="#6F8F77"
                                    Foreground="#10274B"
                                    Style="{StaticResource HomeCardButtonStyle}">
                                    <StackPanel>
                                        <TextBlock Text="ARCHIVIO"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="SCHEDE"
                                                   Margin="0,4,0,0"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </UniformGrid>
                        </Border>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300" />
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="RICERCA RAPIDA"
                                           Style="{StaticResource HomeSectionLabelStyle}" />
                                <Border Margin="0,10,0,0"
                                        Style="{StaticResource HomeDarkPanelStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Consultazione rapida del personale e delle scadenze."
                                                   Foreground="#9AB4D5"
                                                   TextWrapping="Wrap" />

                                        <Button Margin="0,16,0,0"
                                                Command="{Binding NavigateSectionCommand}"
                                                CommandParameter="1"
                                                Background="#F7FBFF"
                                                BorderBrush="#5B84BD"
                                                Foreground="#10274B"
                                                Style="{StaticResource HomeCardButtonStyle}">
                                            <StackPanel>
                                                <TextBlock Text="RICERCA"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="DASHBOARD OPERATIVA"
                                           Style="{StaticResource HomeSectionLabelStyle}" />
                                <Border Margin="0,10,0,0"
                                        Style="{StaticResource HomeDarkPanelStyle}"
                                        Padding="22">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="18" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="18" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="{Binding DashboardStatoSintesi}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="#D7E5F7" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding DashboardScadenzeSintesi}"
                                                   Foreground="#4F73A5"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <UniformGrid Grid.Row="2"
                                                 Columns="2">
                                        <Button Margin="0,0,14,0"
                                                Command="{Binding NavigateSectionCommand}"
                                                CommandParameter="1"
                                                Background="#F8FAFD"
                                                BorderBrush="#A64A4A"
                                                Foreground="#10274B"
                                                Style="{StaticResource HomeMiniCardButtonStyle}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DashboardVisiteScadutePersonale}"
                                                           FontSize="40"
                                                           FontWeight="SemiBold"
                                                           Foreground="#C84848"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Margin="0,10,0,0"
                                                           Text="VISITE MEDICHE"
                                                           TextAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Text="SCADUTE"
                                                           TextAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>

                                        <Button Command="{Binding NavigateSectionCommand}"
                                                CommandParameter="1"
                                                Background="#FBF9F2"
                                                BorderBrush="#B17A26"
                                                Foreground="#10274B"
                                                Style="{StaticResource HomeMiniCardButtonStyle}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DashboardVisiteInScadenzaPersonale}"
                                                           FontSize="40"
                                                           FontWeight="SemiBold"
                                                           Foreground="#B17A26"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Margin="0,10,0,0"
                                                           Text="VISITE MEDICHE"
                                                           TextAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Text="IN SCADENZA"
                                                           TextAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </UniformGrid>

                                    <StackPanel Grid.Row="4">
                                        <TextBlock Text="PERSONALE CON CRITICITA'"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#7FA8DA" />
                                        <ItemsControl Margin="0,12,0,0"
                                                      ItemsSource="{Binding DashboardCriticitaItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8"
                                                            Height="82"
                                                            Background="#12284C"
                                                            BorderBrush="#24406B"
                                                            BorderThickness="1"
                                                            CornerRadius="10"
                                                            Padding="10,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="1.25*" />
                                                                <ColumnDefinition Width="14" />
                                                                <ColumnDefinition Width="1*" />
                                                                <ColumnDefinition Width="14" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding Nominativo}"
                                                                       Foreground="#E4EEF9"
                                                                       FontSize="16"
                                                                       FontWeight="SemiBold"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis" />

                                                            <StackPanel Grid.Column="2"
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Titolo}"
                                                                           Foreground="#D7E5F7"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold"
                                                                           TextAlignment="Right"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding CriticitaDataText}"
                                                                           Foreground="#BFD2EA"
                                                                           FontSize="12"
                                                                           TextAlignment="Right"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>

                                                            <Border Grid.Column="4"
                                                                    Padding="12,6"
                                                                    CornerRadius="6"
                                                                    VerticalAlignment="Center">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="#D1A344" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsExpired}" Value="True">
                                                                                <Setter Property="Background" Value="#B94141" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding CriticitaBadgeText}"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="#5B430F" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsExpired}" Value="True">
                                                                                    <Setter Property="Foreground" Value="#FFF7F3" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Ricerca">
                    <Grid Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="390" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Ricerca personale"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />

                                    <TextBlock Margin="0,14,0,0" Text="Cognome o nome" Foreground="#50626A" />
                                    <TextBox Text="{Binding FiltroCognome, UpdateSourceTrigger=PropertyChanged}" />

                                    <Border Margin="0,8,0,0"
                                            Padding="8"
                                            Background="#F4F7F3"
                                            BorderBrush="#D2DBD6"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Visibility="{Binding IsSearchSuggestionsOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ListBox ItemsSource="{Binding SearchSuggestions}"
                                                 SelectedItem="{Binding SelectedSearchSuggestion}"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 MaxHeight="120"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                    </Border>

                                    <TextBlock Margin="0,12,0,0" Text="Abilitazione" Foreground="#50626A" />
                                    <ComboBox ItemsSource="{Binding FiltroAbilitazioni}"
                                              SelectedItem="{Binding FiltroAbilitazione}"
                                              DisplayMemberPath="Descrizione" />

                                    <TextBlock Margin="0,12,0,0" Text="Visite in scadenza entro" Foreground="#50626A" />
                                    <controls:DateInputPicker Text="{Binding FiltroVisiteEntro, UpdateSourceTrigger=PropertyChanged}"
                                                              Width="150"
                                                              ToolTip="Seleziona la data dal calendario oppure scrivila in formato gg/mm/aaaa" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="Inserisci una data, ad esempio 18/03/2026"
                                               Foreground="#6A7B80"
                                               FontSize="12" />

                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                        <Button Content="Cerca" Command="{Binding SearchCommand}" />
                                        <Button Content="Pulisci"
                                                Command="{Binding ClearFiltersCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Background="#EEF4F8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="{Binding ScadenzeTitolo}"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Foreground="#17313E"
                                                   TextWrapping="Wrap" />
                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Mostra"
                                                       Foreground="#53646A"
                                                       VerticalAlignment="Center" />
                                            <ComboBox Width="170"
                                                      Margin="10,0,0,0"
                                                      ItemsSource="{Binding FiltriScadenze}"
                                                      SelectedItem="{Binding FiltroScadenzeSelezionato}" />
                                        </StackPanel>
                                    </DockPanel>

                                    <Grid Grid.Row="1" Margin="0,14,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Background="#183E5F" CornerRadius="16" Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="Totali"
                                                           Foreground="#C9D7DA"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding ScadenzeTotali}"
                                                           Foreground="#FFF8EE"
                                                           FontSize="24"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Background="#9C3636" CornerRadius="16" Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="Scadute"
                                                           Foreground="#F8DBDB"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding ScadenzeScadute}"
                                                           Foreground="#FFF7F3"
                                                           FontSize="24"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="4" Background="#CFA032" CornerRadius="16" Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="Urgenti 7 gg"
                                                           Foreground="#664B12"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding ScadenzeUrgenti}"
                                                           Foreground="#17313E"
                                                           FontSize="24"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <ScrollViewer Grid.Row="2"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  MaxHeight="420">
                                        <ItemsControl ItemsSource="{Binding ScadenzeProssime}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Margin="0,0,0,10"
                                                            Padding="0"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            Command="{Binding DataContext.OpenScadenzaCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <ContentPresenter />
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                        <Border Padding="12"
                                                                CornerRadius="16"
                                                                Background="{Binding CardBackground}">
                                                            <StackPanel>
                                                                <DockPanel LastChildFill="False">
                                                                    <TextBlock DockPanel.Dock="Left"
                                                                               Text="{Binding Nominativo}"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="#17313E" />
                                                                    <Border DockPanel.Dock="Right"
                                                                            Background="{Binding BadgeBackground}"
                                                                            CornerRadius="999"
                                                                            Padding="8,3">
                                                                        <TextBlock Text="{Binding GiorniResidui}"
                                                                                   Foreground="{Binding BadgeForeground}"
                                                                                   FontSize="12" />
                                                                    </Border>
                                                                </DockPanel>
                                                                <TextBlock Margin="0,2,0,0"
                                                                           Text="{Binding PerId, StringFormat=PerID {0}}"
                                                                           Foreground="#6B7E82"
                                                                           FontSize="12" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding Titolo}"
                                                                           Foreground="{Binding TitoloForeground}"
                                                                           FontWeight="SemiBold" />
                                                                <TextBlock Margin="0,2,0,0"
                                                                           Text="{Binding StatoSintesi}"
                                                                           Foreground="{Binding TitoloForeground}"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold" />
                                                                <TextBlock Margin="0,2,0,0"
                                                                           Text="{Binding Origine}"
                                                                           Foreground="#6B7E82"
                                                                           FontSize="12" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding DataScadenza}"
                                                                           Foreground="#17313E" />
                                                                <TextBlock Margin="0,2,0,0"
                                                                           Text="{Binding Dettaglio}"
                                                                           Foreground="#607176"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Border>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="Elenco dipendenti"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <Button DockPanel.Dock="Right"
                                            Content="Apri scheda"
                                            Command="{Binding OpenSelectedPersonaleCommand}" />
                                </DockPanel>

                                <TextBlock Grid.Row="1"
                                           Margin="0,12,0,0"
                                           Text="Seleziona un nominativo per caricare la scheda completa e passare alla modifica."
                                           Foreground="#53646A"
                                           TextWrapping="Wrap" />

                                <ListBox Grid.Row="2"
                                         Margin="0,16,0,0"
                                         ItemsSource="{Binding PersonaleItems}"
                                         SelectedItem="{Binding SelectedPersonale}"
                                         Height="640"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.CanContentScroll="False"
                                         BorderThickness="0"
                                         Background="Transparent">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0,0,12,12" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="260"
                                                    MinHeight="96"
                                                    Padding="14"
                                                    Background="#F7F9FB"
                                                    BorderBrush="#DCE5EC"
                                                    BorderThickness="1"
                                                    CornerRadius="16">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Nominativo}"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               Foreground="#17313E" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Text="{Binding CodiceFiscale}"
                                                               Foreground="#53646A" />
                                                    <TextBlock Margin="0,2,0,0"
                                                               Text="{Binding Contatti}"
                                                               Foreground="#53646A" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding StatoServizioSintesi}"
                                                               Foreground="#24527B"
                                                               FontWeight="SemiBold" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Servizio giornaliero">
                    <Grid Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Gestione servizi"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="{Binding ServizioBozzaStato}"
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />

                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                        <Button Content="Nuovo servizio"
                                                Command="{Binding NewServizioCommand}"
                                                Style="{StaticResource AccentButtonStyle}" />
                                        <Button Content="Salva servizio"
                                                Command="{Binding SaveServizioCommand}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Button Content="Apri selezionato"
                                                Command="{Binding OpenServizioCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                        <Button Content="Elimina servizio"
                                                Command="{Binding DeleteServizioCommand}"
                                                Style="{StaticResource DangerButtonStyle}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Button Content="Esporta selezionato"
                                                Command="{Binding ExportServizioPackageCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                        <Button Content="Importa servizio"
                                                Command="{Binding ImportServizioPackageCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Button Content="Aggiorna personale"
                                                Command="{Binding ReloadServizioPersonaleCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,12,0,0"
                                    Style="{StaticResource CardStyle}"
                                    Background="#EEF4F8">
                                <StackPanel>
                                    <TextBlock Text="Sintesi operativa"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Background="#173A57"
                                                CornerRadius="16"
                                                Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="Partecipanti"
                                                           Foreground="#C9D7DA"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding ServizioPartecipantiTotali}"
                                                           Foreground="#FFF8EE"
                                                           FontSize="24"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2"
                                                Background="#CFA032"
                                                CornerRadius="16"
                                                Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="Presenti"
                                                           Foreground="#664B12"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding ServizioPresentiTotali}"
                                                           Foreground="#17313E"
                                                           FontSize="24"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                            <Border Margin="0,10,0,0"
                                                    Background="#F8FBFD"
                                                    CornerRadius="16"
                                                    Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Categoria registro"
                                                       Foreground="#53646A"
                                                       FontSize="12" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding ServizioCategoriaRegistroDescrizione}"
                                                       Foreground="#17313E"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,10,0,0"
                                            Background="#F8FBFD"
                                            CornerRadius="16"
                                            Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Tipo servizio"
                                                       Foreground="#53646A"
                                                       FontSize="12" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding ServizioTipoDescrizione}"
                                                       Foreground="#17313E"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding ServizioFuoriSedeDescrizione}"
                                                       Foreground="#53646A" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding ServizioOrdinePubblicoDescrizione}"
                                                       Foreground="#53646A" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding ServizioOrarioRiepilogo}"
                                                       Foreground="#53646A" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding ServizioStraordinarioOreDisplay}"
                                                       Foreground="#53646A" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding ServizioImmersioniCompilate, StringFormat=Immersioni compilate: {0}}"
                                                       Foreground="#53646A" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,12,0,0"
                                    Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Servizi registrati"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="{Binding ServiziSalvatiStato}"
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />

                                    <ListBox Margin="0,14,0,0"
                                             ItemsSource="{Binding ServiziSalvati}"
                                             SelectedItem="{Binding SelectedServizioSalvato}"
                                             MaxHeight="360"
                                             BorderThickness="0"
                                             Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,10"
                                                        Padding="14"
                                                        Background="#F8FBFD"
                                                        BorderBrush="#D8E1E8"
                                                        BorderThickness="1"
                                                        CornerRadius="16">
                                                    <StackPanel>
                                                        <DockPanel LastChildFill="False">
                                                            <TextBlock DockPanel.Dock="Left"
                                                                       Text="{Binding DataServizio, StringFormat={}{0:dd/MM/yyyy}}"
                                                                       FontSize="16"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#17313E" />
                                                            <TextBlock DockPanel.Dock="Right"
                                                                       Text="{Binding TipoServizio}"
                                                                       Foreground="#4F73A5"
                                                                       FontWeight="SemiBold" />
                                                        </DockPanel>
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Foreground="#53646A"
                                                                   TextWrapping="Wrap">
                                                            <Run Text="Ordine: " />
                                                            <Run Text="{Binding NumeroOrdineServizio}" />
                                                            <Run Text=" | Orario: " />
                                                            <Run Text="{Binding OrarioServizio}" />
                                                        </TextBlock>
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Text="{Binding LocalitaDescrizione}"
                                                                   Foreground="#17313E"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Text="{Binding ScopoDescrizione}"
                                                                   Foreground="#53646A"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Foreground="#53646A"
                                                                   TextWrapping="Wrap">
                                                            <Run Text="{Binding PresentiTotali}" />
                                                            <Run Text="/" />
                                                            <Run Text="{Binding PartecipantiTotali}" />
                                                            <Run Text=" presenti" />
                                                            <Run Text=" | Immersioni: " />
                                                            <Run Text="{Binding ImmersioniTotali}" />
                                                        </TextBlock>
                                                        <Button Margin="0,10,0,0"
                                                                Content="Apri servizio"
                                                                HorizontalAlignment="Left"
                                                                Command="{Binding DataContext.OpenServizioFromListCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SecondaryButtonStyle}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <TextBlock Text="{Binding ServizioEditorTitolo}"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="{Binding ServizioEditorSottotitolo}"
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />

                                    <Border Margin="0,18,0,0"
                                            Background="#F2F5F8"
                                            CornerRadius="18"
                                            Padding="16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="170" />
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Data servizio" Foreground="#50626A" />
                                                <controls:DateInputPicker Text="{Binding ServizioData, UpdateSourceTrigger=PropertyChanged}"
                                                                          Width="150"
                                                                          ToolTip="Seleziona la data dal calendario oppure scrivila in formato gg/mm/aaaa" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="N. ordine servizio" Foreground="#50626A" />
                                                <TextBox Text="{Binding ServizioNumeroOrdine, UpdateSourceTrigger=PropertyChanged}"
                                                         MaxLength="40" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="Orario servizio" Foreground="#50626A" />
                                                <Grid Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160" />
                                                        <ColumnDefinition Width="14" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <ComboBox Width="150"
                                                              HorizontalAlignment="Left"
                                                              ItemsSource="{Binding OrariServizioFissiDisponibili}"
                                                              SelectedItem="{Binding ServizioOrarioFissoSelezionato}"
                                                              ToolTip="Seleziona uno degli orari fissi del servizio" />

                                                    <StackPanel Grid.Column="2">
                                                        <CheckBox IsChecked="{Binding ServizioOrarioDerogaAttiva}"
                                                                  Content="Orario in deroga" />
                                                        <StackPanel Margin="0,8,0,0"
                                                                    Orientation="Horizontal"
                                                                    Visibility="{Binding ServizioOrarioDerogaAttiva, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <StackPanel>
                                                                <TextBlock Text="Inizio"
                                                                           Foreground="#50626A"
                                                                           FontSize="11" />
                                                                <TextBox Width="82"
                                                                         Text="{Binding ServizioOrarioDerogaInizio, UpdateSourceTrigger=PropertyChanged}"
                                                                         MaxLength="5"
                                                                         ToolTip="Esempio: 07:30"
                                                                         infra:TimeInputBehavior.AutoFormat="True" />
                                                            </StackPanel>
                                                            <StackPanel Margin="10,0,0,0">
                                                                <TextBlock Text="Fine"
                                                                           Foreground="#50626A"
                                                                           FontSize="11" />
                                                                <TextBox Width="82"
                                                                         Text="{Binding ServizioOrarioDerogaFine, UpdateSourceTrigger=PropertyChanged}"
                                                                         MaxLength="5"
                                                                         ToolTip="Esempio: 14:15"
                                                                         infra:TimeInputBehavior.AutoFormat="True" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>

                                                <Border Margin="0,10,0,0"
                                                        Padding="12"
                                                        Background="#EBF2F7"
                                                        BorderBrush="#D3DFE8"
                                                        BorderThickness="1"
                                                        CornerRadius="14">
                                                    <StackPanel>
                                                        <CheckBox IsChecked="{Binding ServizioStraordinarioAttivo}"
                                                                  Content="Lavoro straordinario" />
                                                        <StackPanel Margin="0,10,0,0"
                                                                    Orientation="Horizontal"
                                                                    Visibility="{Binding ServizioStraordinarioAttivo, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <StackPanel>
                                                                <TextBlock Text="Inizio"
                                                                           Foreground="#50626A"
                                                                           FontSize="11" />
                                                                <TextBox Width="82"
                                                                         Text="{Binding ServizioStraordinarioInizio, UpdateSourceTrigger=PropertyChanged}"
                                                                         MaxLength="5"
                                                                         ToolTip="Esempio: 18:30"
                                                                         infra:TimeInputBehavior.AutoFormat="True" />
                                                            </StackPanel>
                                                            <StackPanel Margin="10,0,0,0">
                                                                <TextBlock Text="Fine"
                                                                           Foreground="#50626A"
                                                                           FontSize="11" />
                                                                <TextBox Width="82"
                                                                         Text="{Binding ServizioStraordinarioFine, UpdateSourceTrigger=PropertyChanged}"
                                                                         MaxLength="5"
                                                                         ToolTip="Esempio: 21:15"
                                                                         infra:TimeInputBehavior.AutoFormat="True" />
                                                            </StackPanel>
                                                            <Border Margin="14,18,0,0"
                                                                    Padding="12,8"
                                                                    Background="#FFFFFF"
                                                                    BorderBrush="#D3DFE8"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10">
                                                                <TextBlock Text="{Binding ServizioStraordinarioOreDisplay}"
                                                                           Foreground="#17313E"
                                                                           FontWeight="SemiBold" />
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Row="1">
                                                <TextBlock Text="Tipo servizio" Foreground="#50626A" />
                                                <ComboBox ItemsSource="{Binding TipiServizioDisponibili}"
                                                          SelectedItem="{Binding ServizioTipoSelezionato}" />
                                            </StackPanel>

                                            <Grid Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="300" />
                                                    <ColumnDefinition Width="18" />
                                                    <ColumnDefinition Width="220" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Localita" Foreground="#50626A" />
                                                    <ComboBox Width="300"
                                                              HorizontalAlignment="Left"
                                                              ItemsSource="{Binding LocalitaOperativeCatalogo}"
                                                              SelectedItem="{Binding ServizioLocalitaSelezionata}"
                                                              DisplayMemberPath="Descrizione" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Unita navale" Foreground="#50626A" />
                                                    <ComboBox Width="220"
                                                              HorizontalAlignment="Left"
                                                              ItemsSource="{Binding UnitaNavaliCatalogo}"
                                                              SelectedItem="{Binding ServizioUnitaNavaleSelezionata}"
                                                              DisplayMemberPath="Descrizione" />
                                                </StackPanel>
                                            </Grid>

                                            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                                <TextBlock Text="Indennita" Foreground="#50626A" />
                                                <CheckBox Margin="0,10,0,0"
                                                          IsChecked="{Binding ServizioFuoriSede}"
                                                          Content="Indennita fuori sede" />
                                                <CheckBox Margin="0,8,0,0"
                                                          IsChecked="{Binding ServizioIndennitaOrdinePubblico}"
                                                          Content="Indennita ordine pubblico" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="Le due indennita non sono compatibili tra loro."
                                                           Foreground="#53646A"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <Grid Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="3" Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="300" />
                                                    <ColumnDefinition Width="18" />
                                                    <ColumnDefinition Width="220" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Nuova localita" Foreground="#50626A" />
                                                    <DockPanel Margin="0,6,0,0" LastChildFill="True">
                                                        <Button DockPanel.Dock="Right"
                                                                Margin="10,0,0,0"
                                                                MinWidth="96"
                                                                Content="Aggiungi"
                                                                Command="{Binding AddLocalitaOperativaCommand}"
                                                                Style="{StaticResource SecondaryButtonStyle}" />
                                                        <TextBox Text="{Binding NuovaLocalitaOperativa, UpdateSourceTrigger=PropertyChanged}"
                                                                 MaxLength="80"
                                                                 ToolTip="Aggiunge una localita permanente nel menu" />
                                                    </DockPanel>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Nuovo mezzo / targa" Foreground="#50626A" />
                                                    <DockPanel Margin="0,6,0,0" LastChildFill="True">
                                                        <Button DockPanel.Dock="Right"
                                                                Margin="10,0,0,0"
                                                                MinWidth="96"
                                                                Content="Aggiungi"
                                                                Command="{Binding AddUnitaNavaleCommand}"
                                                                Style="{StaticResource SecondaryButtonStyle}" />
                                                        <TextBox Text="{Binding NuovaUnitaNavale, UpdateSourceTrigger=PropertyChanged}"
                                                                 MaxLength="80"
                                                                 ToolTip="Aggiunge un mezzo nautico permanente nel menu" />
                                                    </DockPanel>
                                                </StackPanel>
                                            </Grid>

                                            <StackPanel Grid.Row="3" Grid.ColumnSpan="5" Margin="0,10,0,0">
                                                <TextBlock Text="Scopo immersione" Foreground="#50626A" />
                                                <ComboBox ItemsSource="{Binding ScopiImmersioneCatalogo}"
                                                          SelectedItem="{Binding ServizioScopoSelezionato}"
                                                          DisplayMemberPath="Descrizione" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="4" Grid.ColumnSpan="5" Margin="0,10,0,0">
                                                <TextBlock Text="Attivita svolta" Foreground="#50626A" />
                                                <TextBox Text="{Binding ServizioAttivitaSvolta, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap"
                                                         AcceptsReturn="True"
                                                         MinHeight="64" />
                                                <TextBlock Margin="0,10,0,0" Text="Note servizio" Foreground="#50626A" />
                                                <TextBox Text="{Binding ServizioNote, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap"
                                                         AcceptsReturn="True"
                                                         MinHeight="54" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="Personale impiegato"
                                               FontSize="19"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="Seleziona il personale interno del servizio. I contatori ora considerano solo le righe effettivamente compilate."
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />

                                    <DataGrid Margin="0,16,0,0"
                                              ItemsSource="{Binding ServizioPartecipantiBozza}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              HeadersVisibility="Column"
                                              RowHeaderWidth="0"
                                              Sorting="ServizioPartecipantiDataGrid_Sorting"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Qualifica"
                                                                Width="120"
                                                                Binding="{Binding QualificaDisplay}" />
                                            <DataGridTextColumn Header="Cognome e nome"
                                                                Width="220"
                                                                Binding="{Binding Nominativo}" />
                                            <DataGridCheckBoxColumn Header="Presente"
                                                                    Width="90"
                                                                    Binding="{Binding Presente, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridTemplateColumn Header="Gruppo operativo" Width="180">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding GruppoOperativo.Descrizione}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                    <DataTemplate>
                                                        <ComboBox ItemsSource="{Binding DataContext.GruppiOperativiCatalogo, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding GruppoOperativo, UpdateSourceTrigger=PropertyChanged}"
                                                                  DisplayMemberPath="Descrizione" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellEditingTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Ruolo" Width="180">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding RuoloOperativo.Descrizione}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                    <DataTemplate>
                                                        <ComboBox ItemsSource="{Binding DataContext.RuoliOperativiCatalogo, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding RuoloOperativo, UpdateSourceTrigger=PropertyChanged}"
                                                                  DisplayMemberPath="Descrizione" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellEditingTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Contatti"
                                                                Width="220"
                                                                Binding="{Binding Contatti}" />
                                            <DataGridTextColumn Header="Note"
                                                                Width="*"
                                                                Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <DockPanel Margin="0,24,0,0" LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="Assistenza SMZ"
                                                   FontSize="19"
                                                   FontWeight="SemiBold"
                                                   Foreground="#17313E"
                                                   VerticalAlignment="Center" />
                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal">
                                            <Button Content="Aggiungi assistenza SMZ"
                                                    Command="{Binding AddSupportoOccasionaleCommand}"
                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                            <Button Content="Rimuovi selezionato"
                                                    Command="{Binding RemoveSupportoOccasionaleCommand}"
                                                    Style="{StaticResource DangerButtonStyle}" />
                                        </StackPanel>
                                    </DockPanel>
                                    <TextBlock Margin="0,8,0,0"
                                               Text="Usa questa griglia per assistenza SMZ sporadica che non deve entrare in anagrafica. Resta legata solo al singolo servizio."
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />

                                    <DataGrid Margin="0,16,0,0"
                                              ItemsSource="{Binding ServizioSupportiOccasionaliBozza}"
                                              SelectedItem="{Binding SelectedSupportoOccasionale}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              HeadersVisibility="Column"
                                              RowHeaderWidth="0"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Nominativo"
                                                                Width="220"
                                                                Binding="{Binding Nominativo, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridTextColumn Header="Qualifica"
                                                                Width="140"
                                                                Binding="{Binding Qualifica, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridTextColumn Header="Ruolo"
                                                                Width="160"
                                                                Binding="{Binding Ruolo, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridCheckBoxColumn Header="Presente"
                                                                    Width="90"
                                                                    Binding="{Binding Presente, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridTextColumn Header="Contatti"
                                                                Width="180"
                                                                Binding="{Binding Contatti, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridTextColumn Header="Note"
                                                                Width="*"
                                                                Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <TextBlock Margin="0,24,0,0"
                                               Text="Immersioni del servizio"
                                               FontSize="19"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="Compila le immersioni dopo aver selezionato il personale. Gli orari mostrano il formato atteso direttamente nel campo."
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />

                                    <ItemsControl Margin="0,16,0,0"
                                                  ItemsSource="{Binding ServizioImmersioniBozza}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,14,14"
                                                        Background="#F8FBFD"
                                                        BorderBrush="#D8E1E8"
                                                        BorderThickness="1"
                                                        CornerRadius="18"
                                                        Padding="14">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding NumeroImmersione, StringFormat=Immersione {0}}"
                                                                   FontSize="18"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#17313E" />

                                                        <Border Margin="0,12,0,0"
                                                                Background="#EEF6FB"
                                                                BorderBrush="#C8DDEB"
                                                                BorderThickness="1"
                                                                CornerRadius="14"
                                                                Padding="12,10"
                                                                Visibility="Collapsed">
                                                            <StackPanel>
                                                                <DockPanel LastChildFill="False">
                                                                    <TextBlock DockPanel.Dock="Left"
                                                                               Text="Orario immersione"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="#17313E" />
                                                                    <TextBlock DockPanel.Dock="Right"
                                                                               Text="Digita 0830 o 1015, il campo formatta da solo"
                                                                               Foreground="#5B7280"
                                                                               FontSize="11" />
                                                                </DockPanel>

                                                                <StackPanel Margin="0,8,0,0"
                                                                            Orientation="Horizontal"
                                                                            VerticalAlignment="Center">
                                                                    <StackPanel>
                                                                        <TextBlock Text="Inizio"
                                                                                   Foreground="#50626A"
                                                                                   FontSize="11" />
                                                                        <Grid Width="96">
                                                                            <TextBox Style="{StaticResource ImmersionTimeTextBoxStyle}"
                                                                                     Text="{Binding OrarioInizio, UpdateSourceTrigger=PropertyChanged}"
                                                                                     MaxLength="5"
                                                                                     ToolTip="Digita solo cifre, ad esempio 0830"
                                                                                     infra:TimeInputBehavior.AutoFormat="True" />
                                                                            <TextBlock Text="08:30"
                                                                                       Margin="0,8,0,0"
                                                                                       HorizontalAlignment="Center"
                                                                                       Foreground="#9AAAB5"
                                                                                       IsHitTestVisible="False">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding OrarioInizio}" Value="">
                                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </Grid>
                                                                    </StackPanel>

                                                                    <TextBlock Margin="12,20,12,0"
                                                                               Text="→"
                                                                               FontSize="18"
                                                                               FontWeight="Bold"
                                                                               Foreground="#4A7087"
                                                                               VerticalAlignment="Center" />

                                                                    <StackPanel>
                                                                        <TextBlock Text="Fine"
                                                                                   Foreground="#50626A"
                                                                                   FontSize="11" />
                                                                        <Grid Width="96">
                                                                            <TextBox Style="{StaticResource ImmersionTimeTextBoxStyle}"
                                                                                     Text="{Binding OrarioFine, UpdateSourceTrigger=PropertyChanged}"
                                                                                     MaxLength="5"
                                                                                     ToolTip="Digita solo cifre, ad esempio 1015"
                                                                                     infra:TimeInputBehavior.AutoFormat="True" />
                                                                            <TextBlock Text="10:15"
                                                                                       Margin="0,8,0,0"
                                                                                       HorizontalAlignment="Center"
                                                                                       Foreground="#9AAAB5"
                                                                                       IsHitTestVisible="False">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding OrarioFine}" Value="">
                                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </Grid>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>

                                                        <Grid Margin="0,12,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="14" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <StackPanel>
                                                                <TextBlock Text="Direttore immersione" Foreground="#50626A" />
                                                                <ComboBox Margin="0,6,0,0"
                                                                          ItemsSource="{Binding DataContext.OperatoriServizioPresentiDisponibili, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          SelectedItem="{Binding DirettoreImmersione}"
                                                                          DisplayMemberPath="NominativoConQualifica" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="Operatore soccorso" Foreground="#50626A" />
                                                                <ComboBox Margin="0,6,0,0"
                                                                          ItemsSource="{Binding DataContext.OperatoriServizioPresentiDisponibili, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          SelectedItem="{Binding OperatoreSoccorso}"
                                                                          DisplayMemberPath="NominativoConQualifica" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                                                <TextBlock Text="Assistenza BLSD" Foreground="#50626A" />
                                                                <ComboBox Margin="0,6,0,0"
                                                                          ItemsSource="{Binding DataContext.OperatoriServizioPresentiDisponibili, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          SelectedItem="{Binding AssistenteBlsd}"
                                                                          DisplayMemberPath="NominativoConQualifica" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,10,0,0">
                                                                <TextBlock Text="Assistenza sanitaria" Foreground="#50626A" />
                                                                <ComboBox Margin="0,6,0,0"
                                                                          ItemsSource="{Binding DataContext.OperatoriServizioPresentiDisponibili, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          SelectedItem="{Binding AssistenteSanitario}"
                                                                          DisplayMemberPath="NominativoConQualifica" />
                                                            </StackPanel>
                                                        </Grid>

                                                        <DockPanel Margin="0,12,0,0" LastChildFill="False">
                                                            <TextBlock DockPanel.Dock="Left"
                                                                       Text="Dettaglio contabile SMZ"
                                                                       Foreground="#17313E"
                                                                       FontWeight="SemiBold"
                                                                       VerticalAlignment="Center" />
                                                            <StackPanel DockPanel.Dock="Right"
                                                                        Orientation="Horizontal">
                                                                <Button Content="Flagga / deflagga tutti"
                                                                        Padding="10,5"
                                                                        Command="{Binding DataContext.FlaggaTuttiImmersioneCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                                            </StackPanel>
                                                        </DockPanel>
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Text="Compila solo gli operatori SMZ effettivamente entrati in immersione. Profondita e ore vengono allineate automaticamente su tutti gli operatori flaggati della stessa immersione e la profondita viene controllata in base all'apparato."
                                                                   Foreground="#53646A"
                                                                   TextWrapping="Wrap" />

                                                        <DataGrid Margin="0,10,0,0"
                                                                  ItemsSource="{Binding Partecipazioni}"
                                                                  AutoGenerateColumns="False"
                                                                  CanUserAddRows="False"
                                                                  HeadersVisibility="Column"
                                                                  RowHeaderWidth="0"
                                                                  MinHeight="180"
                                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                            <DataGrid.Columns>
                                                                <DataGridCheckBoxColumn Header="In"
                                                                                        Width="42"
                                                                                        Binding="{Binding InImmersione, UpdateSourceTrigger=PropertyChanged}" />
                                                                <DataGridTextColumn Header="Operatore"
                                                                                    Width="250"
                                                                                    Binding="{Binding NominativoConQualifica}" />
                                                                <DataGridTemplateColumn Header="Apparato"
                                                                                        Width="120">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <ComboBox ItemsSource="{Binding DataContext.TipologieImmersioneOperativeCatalogo, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                      SelectedItem="{Binding TipologiaImmersioneOperativa, UpdateSourceTrigger=PropertyChanged}"
                                                                                      DisplayMemberPath="Descrizione" />
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTemplateColumn Header="Prof."
                                                                                        Width="68">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <TextBox Text="{Binding ProfonditaMetri, UpdateSourceTrigger=LostFocus}"
                                                                                     MaxLength="3"
                                                                                     ToolTip="{Binding TipologiaImmersioneOperativa.ProfonditaConsentitaDisplay, TargetNullValue='Seleziona prima l''apparato per vedere il range di profondita.'}" />
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTemplateColumn Header="Fascia"
                                                                                        Width="88">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <ComboBox ItemsSource="{Binding DataContext.FasceProfonditaCatalogo, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                      SelectedItem="{Binding FasciaProfondita, UpdateSourceTrigger=PropertyChanged}"
                                                                                      DisplayMemberPath="Descrizione" />
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTemplateColumn Header="Ore"
                                                                                        Width="68">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <TextBox Text="{Binding OreImmersione, UpdateSourceTrigger=PropertyChanged}" />
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTemplateColumn Header="Cat."
                                                                                        Width="96">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <ComboBox ItemsSource="{Binding DataContext.CategorieContabiliOreCatalogo, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                      SelectedItem="{Binding CategoriaContabileOre, UpdateSourceTrigger=PropertyChanged}"
                                                                                      DisplayMemberPath="Descrizione" />
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTextColumn Header="Tariffa"
                                                                                    Width="72"
                                                                                    Binding="{Binding TariffaPropostaDisplay}" />
                                                                <DataGridTextColumn Header="Importo"
                                                                                    Width="78"
                                                                                    Binding="{Binding ImportoStimatoDisplay}" />
                                                            </DataGrid.Columns>
                                                        </DataGrid>

                                                        <TextBlock Margin="0,10,0,0" Text="Note immersione" Foreground="#50626A" />
                                                        <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                                                 TextWrapping="Wrap"
                                                                 AcceptsReturn="True"
                                                                 MinHeight="44" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Scheda personale">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="Scheda anagrafica"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E"
                                               VerticalAlignment="Center" />
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="Nuovo"
                                                Command="{Binding NewCommand}"
                                                Style="{StaticResource AccentButtonStyle}" />
                                        <Button Content="Salva"
                                                Command="{Binding SaveCommand}" />
                                        <Button Content="Cessa da oggi"
                                                Command="{Binding DeleteCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
