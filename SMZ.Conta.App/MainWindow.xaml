                                                        <ColumnDefinition Width="1.35*" />
                                                        <ColumnDefinition Width="28" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="Scheda misure"
                                                                   FontSize="20"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#17313E" />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Text="{Binding AttagliamentoIndicazioni}"
                                                                   Foreground="#5B6C72"
                                                                   TextWrapping="Wrap" />

                                                        <ItemsControl Margin="0,24,0,0"
                                                                      ItemsSource="{Binding AttagliamentoSchedaItems}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid Margin="0,0,0,18">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="260" />
                                                                            <ColumnDefinition Width="56" />
                                                                            <ColumnDefinition Width="130" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <TextBlock Grid.Column="0"
                                                                                   VerticalAlignment="Center"
                                                                                   FontSize="17"
                                                                                   Foreground="#0F2430"
                                                                                   TextWrapping="Wrap">
                                                                            <TextBlock.Text>
                                                                                <MultiBinding StringFormat="{}{0} - {1}">
                                                                                    <Binding Path="NumeroScheda" />
                                                                                    <Binding Path="EtichettaScheda" />
                                                                                </MultiBinding>
                                                                            </TextBlock.Text>
                                                                        </TextBlock>

                                                                        <TextBlock Grid.Column="1"
                                                                                   VerticalAlignment="Center"
                                                                                   HorizontalAlignment="Right"
                                                                                   FontSize="17"
                                                                                   Foreground="#0F2430"
                                                                                   Text="{Binding UnitaScheda}" />

                                                                        <TextBox Grid.Column="2"
                                                                                 Margin="10,0,0,0"
                                                                                 Padding="10,6"
                                                                                 FontSize="16"
                                                                                 Background="White"
                                                                                 BorderBrush="#B7C7D1"
                                                                                 BorderThickness="1"
                                                                                 HorizontalContentAlignment="Left"
                                                                                 VerticalContentAlignment="Center"
                                                                                 Text="{Binding TagliaMisura, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>

                                                    <Border Grid.Column="2"
                                                            Background="White"
                                                            BorderBrush="#D6E0E7"
                                                            BorderThickness="1"
                                                            CornerRadius="16"
                                                            Padding="12"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Top">
                                                        <Image Source="/Assets/Figura_taglie.png"
                                                               MaxWidth="300"
                                                               Stretch="Uniform"
                                                               SnapsToDevicePixels="True" />
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <Border Margin="0,16,0,0"
                                                    Padding="16"
                                                    Background="#F3F6FA"
                                                    CornerRadius="16"
                                                    Visibility="{Binding HasAttagliamentoAggiuntivo, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <StackPanel>
                                                    <TextBlock Text="Misure aggiuntive gia presenti"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               Foreground="#17313E" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="Le voci non comprese nella scheda principale restano salvate e visibili qui."
                                                               Foreground="#5B6C72"
                                                               TextWrapping="Wrap" />

                                                    <DataGrid Margin="0,12,0,0"
                                                              ItemsSource="{Binding AttagliamentoAggiuntivoItems}"
                                                              AutoGenerateColumns="False"
                                                              CanUserAddRows="False"
                                                              IsReadOnly="False"
                                                              MinHeight="120"
                                                              HeadersVisibility="Column"
                                                              RowHeaderWidth="0">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Voce"
                                                                                Width="220"
                                                                                Binding="{Binding Voce, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                            <DataGridTextColumn Header="Misura"
                                                                                Width="140"
                                                                                Binding="{Binding TagliaMisura, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                            <DataGridTextColumn Header="Note"
                                                                                Width="*"
                                                                                Binding="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>
                            </TabControl>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Archivio">
                    <Grid Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="390" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Schede eliminate recuperabili"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#17313E" />

                                <TextBlock Grid.Row="1"
                                           Margin="0,12,0,0"
                                           Text="Qui trovi solo le schede gia eliminate dalla parte operativa ma ancora recuperabili prima della rimozione definitiva."
                                           Foreground="#53646A"
                                           TextWrapping="Wrap" />

                                <ListBox Grid.Row="2"
                                         Margin="0,16,0,0"
                                         ItemsSource="{Binding ArchivioItems}"
                                         SelectedItem="{Binding SelectedArchivio}"
                                         MaxHeight="640"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.CanContentScroll="False"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         MinHeight="640">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10"
                                                    Padding="14"
                                                    Background="#F2F5F0"
                                                    CornerRadius="16">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Nominativo}"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               Foreground="#17313E" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Text="{Binding PerIdOriginaleLabel}"
                                                               Foreground="#53646A" />
                                                    <TextBlock Margin="0,2,0,0"
                                                               Text="{Binding CodiceFiscale}"
                                                               Foreground="#53646A" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Text="{Binding DataArchiviazioneLabel}"
                                                               Foreground="#6A7B80"
                                                               FontSize="12" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="{Binding ArchivioTitolo}"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Foreground="#17313E" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding ArchivioPerId}"
                                                   Foreground="#53646A" />
                                    </StackPanel>

                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="Ripristina scheda"
                                                Command="{Binding RestoreArchivioCommand}" />
                                        <Button Content="Elimina in modo definitivo"
                                                Command="{Binding DeleteArchivioDefinitivoCommand}"
                                                Style="{StaticResource DangerButtonStyle}" />
                                    </StackPanel>
                                </DockPanel>

                                <TextBlock Grid.Row="1"
                                           Margin="0,12,0,0"
                                           Text="Ripristina per riportare la scheda tra i dipendenti attivi. Usa l'eliminazione definitiva solo quando non serve piu alcun recupero."
                                           Foreground="#53646A"
                                           TextWrapping="Wrap" />

                                <Grid Grid.Row="2" Margin="0,18,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="16" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="16" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Border Background="#EEF4EE"
                                            CornerRadius="18"
                                            Padding="16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.2*" />
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Dettaglio archivio"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="#17313E" />
                                                <TextBlock Margin="0,12,0,0"
                                                           Text="{Binding ArchivioCodiceFiscale}"
                                                           Foreground="#17313E"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding ArchivioContatti}"
                                                           Foreground="#53646A"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding ArchivioDataArchiviazione}"
                                                           Foreground="#6A7B80" />
                                            </StackPanel>

                                            <Grid Grid.Column="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Background="#17313E"
                                                        CornerRadius="16"
                                                        Padding="12">
                                                    <StackPanel>
                                                        <TextBlock Text="Abilitazioni"
                                                                   Foreground="#C9D7DA"
                                                                   FontSize="13" />
                                                        <TextBlock Text="{Binding ArchivioAbilitazioniTotali}"
                                                                   Foreground="#FFF8EE"
                                                                   FontSize="24"
                                                                   FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="2"
                                                        Background="#DFE8F1"
                                                        CornerRadius="16"
                                                        Padding="12">
                                                    <StackPanel>
                                                        <TextBlock Text="Visite mediche"
                                                                   Foreground="#53646A"
                                                                   FontSize="13" />
                                                        <TextBlock Text="{Binding ArchivioVisiteTotali}"
                                                                   Foreground="#17313E"
                                                                   FontSize="24"
                                                                   FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="2"
                                            Background="#FFFCF7"
                                            CornerRadius="18"
                                            Padding="16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="Anagrafica archiviata"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="#17313E" />
                                            <TextBlock Grid.Row="1"
                                                       Margin="0,10,0,0"
                                                       Text="{Binding ArchivioAnagraficaSintesi}"
                                                       Foreground="#53646A"
                                                       TextWrapping="Wrap" />

                                            <DataGrid Grid.Row="2"
                                                      Margin="0,16,0,0"
                                                      ItemsSource="{Binding ArchivioAbilitazioni}"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      MinHeight="220"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                      HeadersVisibility="Column"
                                                      RowHeaderWidth="0">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Tipo"
                                                                        Width="220"
                                                                        Binding="{Binding TipoDescrizione}" />
                                                    <DataGridTextColumn Header="Categoria"
                                                                        Width="120"
                                                                        Binding="{Binding Categoria}" />
                                                    <DataGridTextColumn Header="Livello"
                                                                        Width="110"
                                                                        Binding="{Binding Livello}" />
                                                    <DataGridTextColumn Header="Profondita"
                                                                        Width="95"
                                                                        Binding="{Binding ProfonditaMetri}" />
                                                    <DataGridTextColumn Header="Conseguimento"
                                                                        Width="120"
                                                                        Binding="{Binding DataConseguimento}" />
                                                    <DataGridTextColumn Header="Scadenza"
                                                                        Width="120"
                                                                        Binding="{Binding DataScadenza}" />
                                                    <DataGridTextColumn Header="Note"
                                                                        Width="*"
                                                                        Binding="{Binding Note}" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="4"
                                            Background="#FFFCF7"
                                            CornerRadius="18"
                                            Padding="16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="Visite mediche archiviate"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="#17313E" />

                                            <DataGrid Grid.Row="1"
                                                      Margin="0,16,0,0"
                                                      ItemsSource="{Binding ArchivioVisiteMediche}"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      MinHeight="220"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                      HeadersVisibility="Column"
                                                      RowHeaderWidth="0">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Tipo visita"
                                                                        Width="280"
                                                                        Binding="{Binding TipoVisita}" />
                                                    <DataGridTextColumn Header="Ultima visita"
                                                                        Width="130"
                                                                        Binding="{Binding DataUltimaVisita}" />
                                                    <DataGridTextColumn Header="Scadenza"
                                                                        Width="150"
                                                                        Binding="{Binding DataScadenza}" />
                                                    <DataGridTextColumn Header="Esito"
                                                                        Width="150"
                                                                        Binding="{Binding Esito}" />
                                                    <DataGridTextColumn Header="Note"
                                                                        Width="*"
                                                                        Binding="{Binding Note}" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Contabilita">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{Binding ContabilitaPeriodoTitolo}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="Modulo contabile operativo: riepilogo SMZ immersioni, piu giornate utili e trentesimi per sanitari e Assistenza SMZ."
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="{Binding ElaborazioneMensileStato}"
                                               Foreground="#4F6C84"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <StackPanel Width="170">
                                        <TextBlock Text="Mese"
                                                   Foreground="#50626A" />
                                        <ComboBox ItemsSource="{Binding ContabilitaMesiDisponibili}"
                                                  SelectedItem="{Binding ContabilitaMeseSelezionato}"
                                                  DisplayMemberPath="Descrizione" />
                                    </StackPanel>

                                    <StackPanel Width="110"
                                                Margin="12,0,0,0">
                                        <TextBlock Text="Anno"
                                                   Foreground="#50626A" />
                                        <ComboBox ItemsSource="{Binding ContabilitaAnniDisponibili}"
                                                  SelectedItem="{Binding ContabilitaAnnoSelezionato, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <Button Margin="12,20,0,0"
                                            Content="Aggiorna"
                                            Command="{Binding ReloadContabilitaCommand}" />

                                    <Button Margin="12,20,0,0"
                                            Content="{Binding SalvaElaborazioneMensileLabel}"
                                            Command="{Binding SaveElaborazioneMensileCommand}"
                                            Style="{StaticResource AccentButtonStyle}" />

                                    <Button Margin="12,20,0,0"
                                            Content="Esporta CSV"
                                            Command="{Binding ExportContabilitaCsvCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="Contabilita SMZ immersioni"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="#17313E" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding ContabilitaSmzStato}"
                                                   Foreground="#53646A"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Button DockPanel.Dock="Right"
                                            Padding="10,4"
                                            Content="{Binding ToggleTariffeContabiliLabel}"
                                            Command="{Binding ToggleTariffeContabiliCommand}"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Foreground="#53646A"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Cursor="Hand" />
                                </DockPanel>

                                <TextBlock Grid.Row="1"
                                           Margin="0,14,0,0"
                                           Text="Le righe sono separate per data e ordine di servizio, cosi puoi risalire subito all'origine operativa della contabilita."
                                           Foreground="#6A7B80"
                                           TextWrapping="Wrap" />

                                <DataGrid Grid.Row="2"
                                          Margin="0,16,0,0"
                                          ItemsSource="{Binding ContabilitaSmzItems}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          RowHeaderWidth="0"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Data"
                                                            Width="95"
                                                            Binding="{Binding DataServizioDescrizione}" />
                                        <DataGridTextColumn Header="Ordine"
                                                            Width="120"
                                                            Binding="{Binding NumeroOrdineServizio}" />
                                        <DataGridTextColumn Header="PerID"
                                                            Width="80"
                                                            Binding="{Binding PerId}" />
                                        <DataGridTextColumn Header="Qual."
                                                            Width="110"
                                                            Binding="{Binding QualificaDisplay}" />
                                        <DataGridTextColumn Header="Cognome e nome"
                                                            Width="220"
                                                            Binding="{Binding Nominativo}" />
                                        <DataGridTextColumn Header="Appar."
                                                            Width="95"
                                                            Binding="{Binding Apparato}" />
                                        <DataGridTextColumn Header="Prof."
                                                            Width="80"
                                                            Binding="{Binding FasciaProfondita}" />
                                        <DataGridTextColumn Header="Tariffa"
                                                            Width="75"
                                                            Binding="{Binding TariffaDisplay}" />
                                        <DataGridTextColumn Header="ORE ORD"
                                                            Width="80"
                                                            Binding="{Binding OreOrdDisplay}" />
                                        <DataGridTextColumn Header="ORE ADD"
                                                            Width="80"
                                                            Binding="{Binding OreAddDisplay}" />
                                        <DataGridTextColumn Header="ORE SPER"
                                                            Width="85"
                                                            Binding="{Binding OreSperDisplay}" />
                                        <DataGridTextColumn Header="ORE C.I."
                                                            Width="80"
                                                            Binding="{Binding OreCiDisplay}" />
                                        <DataGridTextColumn Header="Importo"
                                                            Width="90"
                                                            Binding="{Binding ImportoDisplay}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="4"
                                Style="{StaticResource CardStyle}"
                                Visibility="{Binding MostraTariffeContabili, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="Gestione tariffe"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="#17313E" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding TariffeContabiliStato}"
                                                   Foreground="#53646A"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Button DockPanel.Dock="Right"
                                            Content="Salva variazioni"
                                            Command="{Binding SaveTariffeContabiliCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </DockPanel>

                                <TextBlock Grid.Row="1"
                                           Margin="0,12,0,0"
                                           Text="Questa sezione serve solo quando cambiano le tariffe operative. I valori salvati restano nel database e vengono usati nei calcoli successivi."
                                           Foreground="#6A7B80"
                                           TextWrapping="Wrap" />

                                <DataGrid Grid.Row="2"
                                          Margin="0,16,0,0"
                                          ItemsSource="{Binding RegoleContabiliEditorItems}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column"
                                          RowHeaderWidth="0"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          MinHeight="260">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Apparato"
                                                            Width="140"
                                                            Binding="{Binding TipologiaDescrizione}" />
                                        <DataGridTextColumn Header="Fascia"
                                                            Width="90"
                                                            Binding="{Binding FasciaDescrizione}" />
                                        <DataGridTextColumn Header="Categoria"
                                                            Width="110"
                                                            Binding="{Binding CategoriaDescrizione}" />
                                        <DataGridTextColumn Header="Tariffa"
                                                            Width="100"
                                                            Binding="{Binding Tariffa, UpdateSourceTrigger=PropertyChanged}" />
                                        <DataGridCheckBoxColumn Header="Attiva"
                                                                Width="80"
                                                                Binding="{Binding Attiva, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Sanitari impiegati"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <TextBlock Grid.Row="1"
                                               Margin="0,10,0,0"
                                               Text="{Binding ContabilitaSanitariStato}"
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />

                                    <DataGrid Grid.Row="2"
                                              Margin="0,16,0,0"
                                              ItemsSource="{Binding ContabilitaSanitariItems}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              RowHeaderWidth="0"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="PerID"
                                                                Width="80"
                                                                Binding="{Binding PerId}" />
                                            <DataGridTextColumn Header="Nominativo"
                                                                Width="220"
                                                                Binding="{Binding Nominativo}" />
                                            <DataGridTextColumn Header="Qualifica / ruolo"
                                                                Width="200"
                                                                Binding="{Binding QualificaConRuolo}" />
                                            <DataGridTextColumn Header="Giornate"
                                                                Width="90"
                                                                Binding="{Binding GiornateImpiego}" />
                                            <DataGridTextColumn Header="Trentesimi"
                                                                Width="90"
                                                                Binding="{Binding TrentesimiMaturati}" />
                                            <DataGridTextColumn Header="Ultimo servizio"
                                                                Width="120"
                                                                Binding="{Binding UltimaDataServizioDescrizione}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Assistenza SMZ"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <StackPanel Grid.Row="1"
                                                Margin="0,10,0,0">
                                        <TextBlock Text="{Binding ContabilitaSupportoStato}"
                                                   Foreground="#53646A"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="Aggregazione per nominativo: conviene usare sempre la stessa scrittura per avere conteggi coerenti."
                                                   Foreground="#6A7B80"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <DataGrid Grid.Row="2"
                                              Margin="0,16,0,0"
                                              ItemsSource="{Binding ContabilitaSupportiItems}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              RowHeaderWidth="0"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Nominativo"
                                                                Width="220"
                                                                Binding="{Binding Nominativo}" />
                                            <DataGridTextColumn Header="Qualifica / ruolo"
                                                                Width="200"
                                                                Binding="{Binding QualificaConRuolo}" />
                                            <DataGridTextColumn Header="Giornate"
                                                                Width="90"
                                                                Binding="{Binding GiornateImpiego}" />
                                            <DataGridTextColumn Header="Trentesimi"
                                                                Width="90"
                                                                Binding="{Binding TrentesimiMaturati}" />
                                            <DataGridTextColumn Header="Ultimo servizio"
                                                                Width="120"
                                                                Binding="{Binding UltimaDataServizioDescrizione}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Stampe e report">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Stampe e report"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="#17313E" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="Prima area report realmente operativa: registro immersioni mensile derivato dai servizi salvati, con riepilogo per categoria di registro."
                                           Foreground="#53646A"
                                           TextWrapping="Wrap" />
                                <Border Margin="0,16,0,0"
                                        Background="#F4F8FB"
                                        BorderBrush="#D7E1E8"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.35*" />
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Backup dati"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="#17313E" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Text="{Binding BackupDescrizione}"
                                                       Foreground="#53646A"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,12,0,0"
                                                       Text="{Binding BackupLocaleStato}"
                                                       Foreground="#17313E"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding BackupEsternoStato}"
                                                       Foreground="#17313E"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding BackupCartellaEsterna, StringFormat=Cartella esterna: {0}}"
                                                       Foreground="#53646A"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2"
                                                    Width="250">
                                            <Button Content="Crea backup locale"
                                                    Command="{Binding CreateLocalBackupCommand}" />
                                            <Button Content="Crea backup esterno"
                                                    Margin="0,10,0,0"
                                                    Command="{Binding CreateExternalBackupCommand}" />
                                            <Button Content="Configura cartella esterna"
                                                    Margin="0,10,0,0"
                                                    Command="{Binding ConfigureExternalBackupDirectoryCommand}"
                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                            <Button Content="Ripristina da backup"
                                                    Margin="0,10,0,0"
                                                    Command="{Binding RestoreBackupCommand}"
                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2"
                                Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{Binding RegistroImmersioniPeriodoTitolo}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="{Binding RegistroImmersioniStato}"
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="Il registro usa solo immersioni realmente salvate e partecipazioni SMZ presenti nel servizio."
                                               Foreground="#6A7B80"
                                               FontSize="12"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <StackPanel Width="170">
                                        <TextBlock Text="Mese"
                                                   Foreground="#50626A" />
                                        <ComboBox ItemsSource="{Binding ContabilitaMesiDisponibili}"
                                                  SelectedItem="{Binding ContabilitaMeseSelezionato}"
                                                  DisplayMemberPath="Descrizione" />
                                    </StackPanel>

                                    <StackPanel Width="110"
                                                Margin="12,0,0,0">
                                        <TextBlock Text="Anno"
                                                   Foreground="#50626A" />
                                        <ComboBox ItemsSource="{Binding ContabilitaAnniDisponibili}"
                                                  SelectedItem="{Binding ContabilitaAnnoSelezionato, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <Button Margin="12,20,0,0"
                                            Content="Aggiorna registro"
                                            Command="{Binding ReloadRegistroImmersioniCommand}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="Righe del registro"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="#17313E" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="Dettaglio per immersione e per operatore, con localita, scopo, categoria e dati tecnici realmente registrati."
                                                   Foreground="#53646A"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <UniformGrid Grid.Row="1"
                                                 Margin="0,16,0,0"
                                                 Columns="4">
                                        <Border Margin="0,0,12,0"
                                                Background="#F4F8FB"
                                                CornerRadius="16"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Immersioni"
                                                           Foreground="#6A7B80" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding RegistroImmersioniTotaleImmersioni}"
                                                           FontSize="24"
                                                           FontWeight="SemiBold"
                                                           Foreground="#17313E" />
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="0,0,12,0"
                                                Background="#F4F8FB"
                                                CornerRadius="16"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Righe operatore"
                                                           Foreground="#6A7B80" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding RegistroImmersioniTotaleRighe}"
                                                           FontSize="24"
                                                           FontWeight="SemiBold"
                                                           Foreground="#17313E" />
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="0,0,12,0"
                                                Background="#F4F8FB"
                                                CornerRadius="16"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Operatori distinti"
                                                           Foreground="#6A7B80" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding RegistroImmersioniTotaleOperatori}"
                                                           FontSize="24"
                                                           FontWeight="SemiBold"
                                                           Foreground="#17313E" />
                                            </StackPanel>
                                        </Border>

                                        <Border Background="#F4F8FB"
                                                CornerRadius="16"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Ore totali"
                                                           Foreground="#6A7B80" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding RegistroImmersioniTotaleOreDisplay}"
                                                           FontSize="24"
                                                           FontWeight="SemiBold"
                                                           Foreground="#17313E" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <DataGrid Grid.Row="2"
                                              Margin="0,18,0,0"
                                              ItemsSource="{Binding RegistroImmersioniItems}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              RowHeaderWidth="0"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Data"
                                                                Width="75"
                                                                Binding="{Binding DataServizioDescrizione}" />
                                            <DataGridTextColumn Header="Ordine"
                                                                Width="85"
                                                                Binding="{Binding NumeroOrdineServizio}" />
                                            <DataGridTextColumn Header="Imm."
                                                                Width="50"
                                                                Binding="{Binding NumeroImmersione}" />
                                            <DataGridTextColumn Header="Localita"
                                                                Width="0.9*"
                                                                Binding="{Binding Localita}">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap" />
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Scopo"
                                                                Width="1.2*"
                                                                Binding="{Binding ScopoImmersione}">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap" />
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Categoria"
                                                                Width="1.1*"
                                                                Binding="{Binding CategoriaRegistro}">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap" />
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="PerID"
                                                                Width="60"
                                                                Binding="{Binding PerId}" />
                                            <DataGridTextColumn Header="Qual."
                                                                Width="85"
                                                                Binding="{Binding QualificaDisplay}" />
                                            <DataGridTextColumn Header="Nominativo"
                                                                Width="1*"
                                                                Binding="{Binding Nominativo}">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap" />
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="App."
                                                                Width="75"
                                                                Binding="{Binding Apparato}" />
                                            <DataGridTextColumn Header="Prof."
                                                                Width="70"
                                                                Binding="{Binding ProfonditaDisplay}" />
                                            <DataGridTextColumn Header="Fasc."
                                                                Width="55"
                                                                Binding="{Binding FasciaProfondita}" />
                                            <DataGridTextColumn Header="Ore"
                                                                Width="55"
                                                                Binding="{Binding OreImmersioneDisplay}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2"
                                    Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Riepilogo per categoria"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />

                                    <TextBlock Grid.Row="1"
                                               Margin="0,10,0,0"
                                               Text="{Binding RegistroImmersioniCategorieStato}"
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />

                                    <DataGrid Grid.Row="2"
                                              Margin="0,16,0,0"
                                              ItemsSource="{Binding RegistroImmersioniCategorieItems}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              RowHeaderWidth="0"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              MaxHeight="220">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Categoria"
                                                                Width="*"
                                                                Binding="{Binding CategoriaRegistro}" />
                                            <DataGridTextColumn Header="Immersioni"
                                                                Width="90"
                                                                Binding="{Binding ImmersioniTotali}" />
                                            <DataGridTextColumn Header="Righe"
                                                                Width="80"
                                                                Binding="{Binding RigheOperatoreTotali}" />
                                            <DataGridTextColumn Header="Ore"
                                                                Width="75"
                                                                Binding="{Binding OreTotaliDisplay}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </ScrollViewer>

        <Border Grid.Row="2"
                Margin="0,18,0,0"
                Background="#DDE7E2"
                CornerRadius="18"
                Padding="14,10">
            <TextBlock Text="{Binding Stato}"
                       Foreground="#17313E"
                       FontSize="14" />
        </Border>

        <Grid Grid.RowSpan="3"
              Panel.ZIndex="20"
              Visibility="{Binding IsWelcomeVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#C7061320"
                    CornerRadius="28" />

            <Border Margin="12"
                    CornerRadius="30"
                    Background="Transparent"
                    ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="44"
                                      ShadowDepth="14"
                                      Direction="270"
                                      Opacity="0.34"
                                      Color="#02070D" />
                </Border.Effect>

                <Grid>
                    <Border Background="{StaticResource HomePhotoBrush}" />
                    <Rectangle Fill="{StaticResource WelcomeScreenOverlayBrush}" />

                    <Ellipse Width="760"
                             Height="280"
                             Margin="0,-136,0,0"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Top"
                             Opacity="0.32"
                             IsHitTestVisible="False"
                             RenderTransformOrigin="0.5,0">
                        <Ellipse.Fill>
                            <RadialGradientBrush GradientOrigin="0.5,0.18">
                                <GradientStop Color="#D3A94A" Offset="0" />
                                <GradientStop Color="#7CC7E7F3" Offset="0.34" />
                                <GradientStop Color="#00C7E7F3" Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.Effect>
                            <BlurEffect Radius="64" />
                        </Ellipse.Effect>
                        <Ellipse.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0.26"
                                                         To="0.42"
                                                         Duration="0:0:6.8" />
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                         From="0.96"
                                                         To="1.05"
                                                         Duration="0:0:6.8" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>

                    <Rectangle Height="1"
                               Margin="64,108,64,0"
                               VerticalAlignment="Top"
                               Fill="#4295C5EA"
                               Opacity="0.56"
                               IsHitTestVisible="False" />

                    <Rectangle Width="1"
                               Height="250"
                               Margin="0,150,220,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Top"
                               Fill="#225A84A8"
                               IsHitTestVisible="False" />

                    <Rectangle Width="1"
                               Height="210"
                               Margin="0,220,116,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Top"
                               Fill="#184F789A"
                               IsHitTestVisible="False" />

                    <Ellipse Width="124"
                             Height="124"
                             Margin="0,140,300,0"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             Fill="#18A3D8F4"
                             Stroke="#56C1E6F8"
                             StrokeThickness="1"
                             Opacity="0.22"
                             IsHitTestVisible="False">
                        <Ellipse.Effect>
                            <BlurEffect Radius="8" />
                        </Ellipse.Effect>
                        <Ellipse.RenderTransform>
                            <TranslateTransform />
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0.16"
                                                         To="0.32"
                                                         Duration="0:0:8" />
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                         From="0"
                                                         To="-26"
                                                         Duration="0:0:8" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>

                    <Ellipse Width="88"
                             Height="88"
                             Margin="0,430,420,0"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             Fill="#16C8E5FF"
                             Stroke="#5AA2D0F0"
                             StrokeThickness="1"
                             Opacity="0.18"
                             IsHitTestVisible="False">
                        <Ellipse.Effect>
                            <BlurEffect Radius="6" />
                        </Ellipse.Effect>
                        <Ellipse.RenderTransform>
                            <TranslateTransform />
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0.12"
                                                         To="0.28"
                                                         Duration="0:0:10" />
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                         From="0"
                                                         To="-18"
                                                         Duration="0:0:10" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>

                    <Ellipse Width="154"
                             Height="154"
                             Margin="160,0,0,110"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Bottom"
                             Fill="#12A8D6EE"
                             Stroke="#4690C2E6"
                             StrokeThickness="1"
                             Opacity="0.16"
                             IsHitTestVisible="False">
                        <Ellipse.Effect>
                            <BlurEffect Radius="10" />
                        </Ellipse.Effect>
                        <Ellipse.RenderTransform>
                            <TranslateTransform />
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0.1"
                                                         To="0.24"
                                                         Duration="0:0:11" />
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                         From="0"
                                                         To="-20"
                                                         Duration="0:0:11" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>

                    <Viewbox Margin="28"
                             Stretch="Uniform"
                             StretchDirection="DownOnly">
                        <Grid Width="1480"
                              Height="820">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="0.9*" />
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0"
                                    Grid.RowSpan="3"
                                    Width="660"
                                    Margin="0,20,38,40"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Border HorizontalAlignment="Center"
                                    Padding="20,12"
                                    CornerRadius="999"
                                    Background="#140C1D31"
                                    BorderBrush="#53779C"
                                    BorderThickness="1">
                                <TextBlock Text="GESTIONALE OPERATIVO - NUCLEO SOMMOZZATORI"
                                           Foreground="#DDEAF7"
                                           FontSize="16"
                                           FontWeight="Bold" />
                            </Border>

                            <TextBlock Margin="0,30,0,0"
                                       Text="{Binding WelcomeTitolo}"
                                       FontSize="54"
                                       FontWeight="Bold"
                                       Foreground="#FFFDF7"
                                       TextAlignment="Center"
                                       TextWrapping="NoWrap" />

                            <TextBlock Margin="0,10,0,0"
                                       Text="LA SPEZIA"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="#FFFFFF"
                                       TextAlignment="Center" />

                            <Image Width="182"
                                   Height="138"
                                   Margin="0,28,0,0"
                                   Source="Assets/logo_smz.png"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center" />

                            <TextBlock Margin="0,24,0,0"
                                       MaxWidth="560"
                                       Text="{Binding WelcomeSottotitolo}"
                                       FontSize="19"
                                       Foreground="#D9E5F2"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />

                            <WrapPanel Margin="0,28,0,0"
                                       HorizontalAlignment="Center"
                                       ItemHeight="64"
                                       MaxWidth="620">
                                <Border Style="{StaticResource WelcomeFeatureChipStyle}">
                                    <StackPanel>
                                        <TextBlock Text="SERVIZI GIORNALIERI"
                                                   Foreground="#FFF7DC"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="Pianificazione rapida"
                                                   Foreground="#A9C6E2"
                                                   FontSize="12" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource WelcomeFeatureChipStyle}">
                                    <StackPanel>
                                        <TextBlock Text="PERSONALE E ARCHIVIO"
                                                   Foreground="#FFF7DC"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="Schede e storico operativo"
                                                   Foreground="#A9C6E2"
                                                   FontSize="12" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource WelcomeFeatureChipStyle}">
                                    <StackPanel>
                                        <TextBlock Text="CONTABILITA E REPORT"
                                                   Foreground="#FFF7DC"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="Visione unificata del reparto"
                                                   Foreground="#A9C6E2"
                                                   FontSize="12" />
                                    </StackPanel>
                                </Border>
                            </WrapPanel>

                            <Button Margin="0,34,0,0"
                                    Content="Entra nel gestionale"
                                    Command="{Binding EnterAppCommand}"
                                    IsDefault="True"
                                    HorizontalAlignment="Center"
                                    Style="{StaticResource WelcomeEnterButtonStyle}" />

                            <TextBlock Margin="0,16,0,0"
                                       MaxWidth="520"
                                       Text="Accesso diretto alla home iniziale con dashboard, anagrafica, servizi, immersioni e riepiloghi."
                                       Foreground="#A8C2DF"
                                       FontSize="14"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Content="AUDIO"
                                Command="{Binding ToggleWelcomeAudioCommand}"
                                ToolTip="{Binding WelcomeAudioTooltip}"
                                Style="{StaticResource WelcomeAudioButtonStyle}" />

                        <Grid Grid.Column="1"
                              Grid.Row="1"
                              Margin="24,26,0,48">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="22" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="20" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource WelcomeHudCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="22" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="20" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="PANORAMICA OPERATIVA"
                                                   Style="{StaticResource WelcomeHudLabelStyle}" />
                                        <TextBlock Margin="0,12,0,0"
                                                   Text="{Binding DashboardStatoSintesi}"
                                                   Foreground="#F4F8FC"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,10,0,0"
                                                   Text="{Binding DashboardScadenzeSintesi}"
                                                   Foreground="#AFC8E0"
                                                   FontSize="14"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <UniformGrid Grid.Row="2"
                                                 Columns="2">
                                        <Border Style="{StaticResource WelcomeMetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="PERSONALE"
                                                           Style="{StaticResource WelcomeHudLabelStyle}" />
                                                <TextBlock Margin="0,10,0,0"
                                                           Text="{Binding DashboardDipendentiTotali}"
                                                           Style="{StaticResource WelcomeHudValueStyle}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="operatori registrati"
                                                           Foreground="#A9C1D8" />
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource WelcomeMetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="SCADENZE"
                                                           Style="{StaticResource WelcomeHudLabelStyle}" />
                                                <TextBlock Margin="0,10,0,0"
                                                           Text="{Binding DashboardScadenzeAperte}"
                                                           Style="{StaticResource WelcomeHudValueStyle}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="voci da monitorare"
                                                           Foreground="#A9C1D8" />
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource WelcomeMetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="VISITE"
                                                           Style="{StaticResource WelcomeHudLabelStyle}" />
                                                <TextBlock Margin="0,10,0,0"
                                                           Text="{Binding DashboardVisiteInScadenzaPersonale}"
                                                           Style="{StaticResource WelcomeHudValueStyle}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="personale in scadenza"
                                                           Foreground="#A9C1D8" />
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="0,0,0,16"
                                                CornerRadius="20"
                                                Padding="18"
                                                Background="#140D1F33"
                                                BorderBrush="#345B7B"
                                                BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="MODULI"
                                                           Style="{StaticResource WelcomeHudLabelStyle}" />
                                                <TextBlock Margin="0,10,0,0"
                                                           Text="{Binding DashboardCataloghiServizioTotali}"
                                                           Style="{StaticResource WelcomeHudValueStyle}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="cataloghi operativi"
                                                           Foreground="#A9C1D8" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <Grid Grid.Row="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border
                                                CornerRadius="20"
                                                Padding="18"
                                                Background="#120C2036"
                                                BorderBrush="#31597B"
                                                BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="SERVIZI GIORNALIERI"
                                                           Foreground="#F9E7B0"
                                                           FontSize="16"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Margin="0,12,0,0"
                                                           Text="{Binding DashboardServizioSintesi}"
                                                           Foreground="#C8D8E9"
                                                           TextWrapping="Wrap" />
                                                <Border Margin="0,16,0,0"
                                                        Height="6"
                                                        HorizontalAlignment="Stretch"
                                                        Background="#193C5674"
                                                        CornerRadius="999">
                                                    <Border Width="150"
                                                            HorizontalAlignment="Left"
                                                            Background="#F2D37B"
                                                            CornerRadius="999" />
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2"
                                                CornerRadius="20"
                                                Padding="18"
                                                Background="#120C2036"
                                                BorderBrush="#31597B"
                                                BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DashboardTopScadenzeTitolo}"
                                                           Foreground="#F9E7B0"
                                                           FontSize="16"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Margin="0,12,0,0"
                                                           Text="{Binding DashboardArchivioSintesi}"
                                                           Foreground="#C8D8E9"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,14,0,0"
                                                           Text="{Binding DashboardScadenzeSintesi}"
                                                           Foreground="#9FBBD6"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="2"
                                    Grid.ColumnSpan="2"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,10">
                            <TextBlock Text="{Binding WelcomeCredits}"
                                       Style="{StaticResource WelcomeMetaTextStyle}" />
                            <TextBlock Margin="22,0,0,0"
                                       Text="{Binding WelcomeVersione}"
                                       Style="{StaticResource WelcomeMetaTextStyle}" />
                        </StackPanel>
                        </Grid>
                    </Viewbox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
