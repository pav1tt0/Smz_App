                                               Foreground="#6A7B80"
                                               FontSize="12"
                                               TextWrapping="Wrap" />

                                    <TextBlock Margin="0,20,0,0"
                                               Text="Dati anagrafici"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <Grid Margin="0,16,0,0">
