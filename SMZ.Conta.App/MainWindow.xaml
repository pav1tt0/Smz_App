<Window x:Class="SMZ.Conta.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:infra="clr-namespace:SMZ.Conta.App.Infrastructure"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Titolo}"
        Width="1520"
        Height="960"
        MinWidth="1320"
        MinHeight="780"
        WindowState="Maximized"
        Background="#0A1628"
        FontFamily="Bahnschrift">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFCF7"/>
            <Setter Property="BorderBrush" Value="#D8E1E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#C9D5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="DateTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="150"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="HiddenTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <ContentPresenter ContentSource="SelectedContent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#E6EDF5"/>
            <Setter Property="BorderBrush" Value="#CFDAE5"/>
            <Setter Property="Foreground" Value="#4B6175"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12,12,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#F0F5FA"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#143A63"/>
                                <Setter TargetName="TabBorder" Property="Background" Value="#FFFCF7"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#C9D8E7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TabBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="MinWidth" Value="132"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#174E78"/>
            <Setter Property="Foreground" Value="#FFFDF7"/>
            <Setter Property="BorderBrush" Value="#174E78"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.48"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}" />

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#DFE8F1"/>
            <Setter Property="BorderBrush" Value="#DFE8F1"/>
            <Setter Property="Foreground" Value="#17313E"/>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#CFA032"/>
            <Setter Property="BorderBrush" Value="#CFA032"/>
            <Setter Property="Foreground" Value="#17313E"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#8F3434"/>
            <Setter Property="BorderBrush" Value="#8F3434"/>
            <Setter Property="Foreground" Value="#FFF7F3"/>
        </Style>

        <Style x:Key="HomeCardButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#C7D5E2"/>
            <Setter Property="Foreground" Value="#0F2E47"/>
            <Setter Property="MinWidth" Value="240"/>
            <Setter Property="MinHeight" Value="128"/>
            <Setter Property="Padding" Value="22,18"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="CardBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1.2"
                                    CornerRadius="26"
                                    SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="24"
                                                      ShadowDepth="8"
                                                      Direction="270"
                                                      Opacity="0.18"
                                                      Color="#15314A" />
                                </Border.Effect>
                            </Border>

                            <Border x:Name="AccentBar"
                                    Height="8"
                                    Margin="18,16,18,0"
                                    VerticalAlignment="Top"
                                    Background="{TemplateBinding BorderBrush}"
                                    CornerRadius="999" />

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#8EA9BE" />
                                <Setter TargetName="CardBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="30"
                                                          ShadowDepth="12"
                                                          Direction="270"
                                                          Opacity="0.28"
                                                          Color="#173A57" />
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="-4" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="-1" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CardBorder" Property="Opacity" Value="0.55" />
                                <Setter TargetName="AccentBar" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HomeMiniCardButtonStyle" TargetType="Button" BasedOn="{StaticResource HomeCardButtonStyle}">
            <Setter Property="MinWidth" Value="220"/>
            <Setter Property="MinHeight" Value="120"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <Style x:Key="HomeSectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4F73A5"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="HomeDarkPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="#0F2040"/>
            <Setter Property="BorderBrush" Value="#1E3860"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="HeaderHomeButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="#F5FAFF"/>
            <Setter Property="BorderBrush" Value="#7FA8DA"/>
            <Setter Property="Foreground" Value="#10274B"/>
            <Setter Property="MinWidth" Value="118"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsHomeSection}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <ImageBrush x:Key="HomePhotoBrush"
                    ImageSource="Assets/smz.jpg"
                    Stretch="UniformToFill" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="#2A5298"
                BorderThickness="1.4"
                CornerRadius="22"
                Padding="20"
                Margin="0,0,0,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0D2040" Offset="0" />
                    <GradientStop Color="#1A3A6B" Offset="0.52" />
                    <GradientStop Color="#0D2040" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <Border Width="124"
                        Height="94"
                        Padding="12"
                        CornerRadius="18"
                        BorderBrush="#4A7CC7"
                        BorderThickness="1"
                        Background="#0A1628"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="22"
                                          ShadowDepth="8"
                                          Direction="270"
                                          Opacity="0.2"
                                          Color="#09111E" />
                    </Border.Effect>
                    <Image Source="Assets/logo_smz.png"
                           Stretch="Uniform" />
                </Border>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="POLIZIA DI STATO"
                            FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="#D7E5F7"
                               HorizontalAlignment="Center" />
                    <TextBlock Margin="0,4,0,0"
                               Text="NUCLEO SOMMOZZATORI"
                               FontSize="21"
                               Foreground="#7FA8DA"
                               HorizontalAlignment="Center" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Gestione operativa di servizi giornalieri, personale e contabilita"
                               FontSize="13"
                               Foreground="#5F8CCC"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <Grid Grid.Column="2" Margin="24,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="← Home"
                                Command="{Binding NavigateSectionCommand}"
                                CommandParameter="0"
                                ToolTip="Torna alla schermata iniziale"
                                Style="{StaticResource HeaderHomeButtonStyle}" />
                    </StackPanel>

                    <Border Grid.Row="2"
                            Height="94"
                            CornerRadius="18"
                            BorderBrush="#284A78"
                            BorderThickness="1.2"
                            Background="{StaticResource HomePhotoBrush}"
                            VerticalAlignment="Center">
                        <Grid>
                            <Rectangle RadiusX="18"
                                       RadiusY="18"
                                       Fill="#500A1628" />
                            <StackPanel VerticalAlignment="Bottom"
                                        Margin="16">
                                <TextBlock Text="La Spezia"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#FFF8EE" />
                                <TextBlock Margin="0,3,0,0"
                                           Text="Accesso rapido ai moduli principali"
                                           Foreground="#D9E5EA" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <TabControl SelectedIndex="{Binding SezioneAttivaIndex}"
                        Style="{StaticResource HiddenTabControlStyle}">
                <TabItem Header="Home">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="28" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="MODULI PRINCIPALI"
                                       Style="{StaticResource HomeSectionLabelStyle}" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="Accesso diretto alle aree usate ogni giorno dal nucleo."
                                       FontSize="14"
                                       Foreground="#A7C0DF" />
                        </StackPanel>

                        <Border Grid.Row="2"
                                Style="{StaticResource HomeDarkPanelStyle}"
                                Padding="22">
                            <UniformGrid Columns="4">
                                <Button Margin="0,0,18,0"
                                    Command="{Binding NavigateSectionCommand}"
                                    CommandParameter="2"
                                    Background="#F6FAFF"
                                    BorderBrush="#5B84BD"
                                    Foreground="#10274B"
                                    Style="{StaticResource HomeCardButtonStyle}">
                                    <StackPanel>
                                        <TextBlock Text="SERVIZIO"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="GIORNALIERO"
                                                   Margin="0,4,0,0"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Margin="0,12,0,0"
                                                   Text="Turni, equipaggi, immersioni"
                                                   FontSize="12"
                                                   Foreground="#5A7190"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Margin="0,0,18,0"
                                    Command="{Binding NavigateSectionCommand}"
                                    CommandParameter="3"
                                    Background="#F8FBFD"
                                    BorderBrush="#7A94AC"
                                    Foreground="#10274B"
                                    Style="{StaticResource HomeCardButtonStyle}">
                                    <StackPanel>
                                        <TextBlock Text="ANAGRAFICA"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="PERSONALE"
                                                   Margin="0,4,0,0"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Margin="0,12,0,0"
                                                   Text="Schede, qualifiche, scadenze"
                                                   FontSize="12"
                                                   Foreground="#5A7190"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Margin="0,0,18,0"
                                    Command="{Binding NavigateSectionCommand}"
                                    CommandParameter="2"
                                    Background="#F4FAFF"
                                    BorderBrush="#3E7AA6"
                                    Foreground="#10274B"
                                    Style="{StaticResource HomeCardButtonStyle}">
                                    <StackPanel>
                                        <TextBlock Text="CONTABILITA'"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Margin="0,12,0,0"
                                                   Text="Ore, missioni, riepiloghi"
                                                   FontSize="12"
                                                   Foreground="#5A7190"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button IsEnabled="False"
                                    Background="#DFE5EC"
                                    BorderBrush="#5A6F89"
                                    Foreground="#56697E"
                                    Style="{StaticResource HomeCardButtonStyle}">
                                    <StackPanel>
                                        <TextBlock Text="STAMPE E"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="REPORT"
                                                   Margin="0,4,0,0"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Margin="0,12,0,0"
                                                   Text="Modulo previsto, non ancora attivo"
                                                   FontSize="12"
                                                   Foreground="#6F8193"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </UniformGrid>
                        </Border>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300" />
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="RICERCA RAPIDA"
                                           Style="{StaticResource HomeSectionLabelStyle}" />
                                <Border Margin="0,10,0,0"
                                        Style="{StaticResource HomeDarkPanelStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Consultazione rapida del personale e delle scadenze."
                                                   Foreground="#9AB4D5"
                                                   TextWrapping="Wrap" />

                                        <Button Margin="0,16,0,0"
                                                Command="{Binding NavigateSectionCommand}"
                                                CommandParameter="1"
                                                Background="#F7FBFF"
                                                BorderBrush="#5B84BD"
                                                Foreground="#10274B"
                                                Style="{StaticResource HomeCardButtonStyle}">
                                            <StackPanel>
                                                <TextBlock Text="RICERCA"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Margin="0,12,0,0"
                                                           Text="Matricola, nominativo, abilitazioni"
                                                           FontSize="12"
                                                           Foreground="#5A7190"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="DASHBOARD OPERATIVA"
                                           Style="{StaticResource HomeSectionLabelStyle}" />
                                <Border Margin="0,10,0,0"
                                        Style="{StaticResource HomeDarkPanelStyle}"
                                        Padding="22">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="18" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="18" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="{Binding DashboardStatoSintesi}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="#D7E5F7" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding DashboardScadenzeSintesi}"
                                                   Foreground="#4F73A5"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <UniformGrid Grid.Row="2"
                                                 Columns="2">
                                        <Button Margin="0,0,14,0"
                                                Command="{Binding NavigateSectionCommand}"
                                                CommandParameter="1"
                                                Background="#F8FAFD"
                                                BorderBrush="#A64A4A"
                                                Foreground="#10274B"
                                                Style="{StaticResource HomeMiniCardButtonStyle}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DashboardVisiteScadutePersonale}"
                                                           FontSize="40"
                                                           FontWeight="SemiBold"
                                                           Foreground="#C84848"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Margin="0,10,0,0"
                                                           Text="VISITE MEDICHE"
                                                           TextAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Text="SCADUTE"
                                                           TextAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>

                                        <Button Command="{Binding NavigateSectionCommand}"
                                                CommandParameter="1"
                                                Background="#FBF9F2"
                                                BorderBrush="#B17A26"
                                                Foreground="#10274B"
                                                Style="{StaticResource HomeMiniCardButtonStyle}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DashboardVisiteInScadenzaPersonale}"
                                                           FontSize="40"
                                                           FontWeight="SemiBold"
                                                           Foreground="#B17A26"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Margin="0,10,0,0"
                                                           Text="VISITE MEDICHE"
                                                           TextAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Text="IN SCADENZA"
                                                           TextAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </UniformGrid>

                                    <StackPanel Grid.Row="4">
                                        <TextBlock Text="PERSONALE CON CRITICITA'"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#7FA8DA" />
                                        <ItemsControl Margin="0,12,0,0"
                                                      ItemsSource="{Binding DashboardCriticitaItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8"
                                                            Background="#12284C"
                                                            BorderBrush="#24406B"
                                                            BorderThickness="1"
                                                            CornerRadius="10"
                                                            Padding="10,8">
                                                        <DockPanel LastChildFill="False">
                                                            <StackPanel DockPanel.Dock="Left">
                                                                <TextBlock Text="{Binding Nominativo}"
                                                                           Foreground="#BCD1EC"
                                                                           FontWeight="SemiBold" />
                                                                <TextBlock Margin="0,3,0,0"
                                                                           Text="{Binding Titolo}"
                                                                           Foreground="#4F73A5"
                                                                           FontSize="11" />
                                                            </StackPanel>
                                                            <Border DockPanel.Dock="Right"
                                                                    Padding="8,3"
                                                                    Background="{Binding BadgeBackground}"
                                                                    CornerRadius="999">
                                                                <TextBlock Text="{Binding GiorniResidui}"
                                                                           Foreground="{Binding BadgeForeground}"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold" />
                                                            </Border>
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Ricerca">
                    <Grid Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="390" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Ricerca personale"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />

                                    <TextBlock Margin="0,14,0,0" Text="Cognome o nome" Foreground="#50626A" />
                                    <TextBox Text="{Binding FiltroCognome, UpdateSourceTrigger=PropertyChanged}" />

                                    <Border Margin="0,8,0,0"
                                            Padding="8"
                                            Background="#F4F7F3"
                                            BorderBrush="#D2DBD6"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Visibility="{Binding IsSearchSuggestionsOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ListBox ItemsSource="{Binding SearchSuggestions}"
                                                 SelectedItem="{Binding SelectedSearchSuggestion}"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 MaxHeight="120"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                    </Border>

                                    <TextBlock Margin="0,12,0,0" Text="Abilitazione" Foreground="#50626A" />
                                    <ComboBox ItemsSource="{Binding FiltroAbilitazioni}"
                                              SelectedItem="{Binding FiltroAbilitazione}"
                                              DisplayMemberPath="Descrizione" />

                                    <TextBlock Margin="0,12,0,0" Text="Visite in scadenza entro" Foreground="#50626A" />
                                    <TextBox Text="{Binding FiltroVisiteEntro, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource DateTextBoxStyle}"
                                             MaxLength="10"
                                             ToolTip="Digita 18032026 oppure 18/03/2026"
                                             infra:DateInputBehavior.AutoFormat="True" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="Inserisci una data, ad esempio 18/03/2026"
                                               Foreground="#6A7B80"
                                               FontSize="12" />

                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                        <Button Content="Cerca" Command="{Binding SearchCommand}" />
                                        <Button Content="Pulisci"
                                                Command="{Binding ClearFiltersCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Background="#EEF4F8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="{Binding ScadenzeTitolo}"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Foreground="#17313E"
                                                   TextWrapping="Wrap" />
                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Mostra"
                                                       Foreground="#53646A"
                                                       VerticalAlignment="Center" />
                                            <ComboBox Width="170"
                                                      Margin="10,0,0,0"
                                                      ItemsSource="{Binding FiltriScadenze}"
                                                      SelectedItem="{Binding FiltroScadenzeSelezionato}" />
                                        </StackPanel>
                                    </DockPanel>

                                    <Grid Grid.Row="1" Margin="0,14,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Background="#183E5F" CornerRadius="16" Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="Totali"
                                                           Foreground="#C9D7DA"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding ScadenzeTotali}"
                                                           Foreground="#FFF8EE"
                                                           FontSize="24"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Background="#9C3636" CornerRadius="16" Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="Scadute"
                                                           Foreground="#F8DBDB"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding ScadenzeScadute}"
                                                           Foreground="#FFF7F3"
                                                           FontSize="24"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="4" Background="#CFA032" CornerRadius="16" Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="Urgenti 7 gg"
                                                           Foreground="#664B12"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding ScadenzeUrgenti}"
                                                           Foreground="#17313E"
                                                           FontSize="24"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <ScrollViewer Grid.Row="2"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  MaxHeight="420">
                                        <ItemsControl ItemsSource="{Binding ScadenzeProssime}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Margin="0,0,0,10"
                                                            Padding="0"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            Command="{Binding DataContext.OpenScadenzaCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <ContentPresenter />
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                        <Border Padding="12"
                                                                CornerRadius="16"
                                                                Background="{Binding CardBackground}">
                                                            <StackPanel>
                                                                <DockPanel LastChildFill="False">
                                                                    <TextBlock DockPanel.Dock="Left"
                                                                               Text="{Binding Nominativo}"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="#17313E" />
                                                                    <Border DockPanel.Dock="Right"
                                                                            Background="{Binding BadgeBackground}"
                                                                            CornerRadius="999"
                                                                            Padding="8,3">
                                                                        <TextBlock Text="{Binding GiorniResidui}"
                                                                                   Foreground="{Binding BadgeForeground}"
                                                                                   FontSize="12" />
                                                                    </Border>
                                                                </DockPanel>
                                                                <TextBlock Margin="0,2,0,0"
                                                                           Text="{Binding PerId, StringFormat=PerID {0}}"
                                                                           Foreground="#6B7E82"
                                                                           FontSize="12" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding Titolo}"
                                                                           Foreground="{Binding TitoloForeground}"
                                                                           FontWeight="SemiBold" />
                                                                <TextBlock Margin="0,2,0,0"
                                                                           Text="{Binding StatoSintesi}"
                                                                           Foreground="{Binding TitoloForeground}"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold" />
                                                                <TextBlock Margin="0,2,0,0"
                                                                           Text="{Binding Origine}"
                                                                           Foreground="#6B7E82"
                                                                           FontSize="12" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding DataScadenza}"
                                                                           Foreground="#17313E" />
                                                                <TextBlock Margin="0,2,0,0"
                                                                           Text="{Binding Dettaglio}"
                                                                           Foreground="#607176"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Border>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="Elenco dipendenti"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <Button DockPanel.Dock="Right"
                                            Content="Apri scheda"
                                            Command="{Binding OpenSelectedPersonaleCommand}" />
                                </DockPanel>

                                <TextBlock Grid.Row="1"
                                           Margin="0,12,0,0"
                                           Text="Seleziona un nominativo per caricare la scheda completa e passare alla modifica."
                                           Foreground="#53646A"
                                           TextWrapping="Wrap" />

                                <ListBox Grid.Row="2"
                                         Margin="0,16,0,0"
                                         ItemsSource="{Binding PersonaleItems}"
                                         SelectedItem="{Binding SelectedPersonale}"
                                         MaxHeight="640"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.CanContentScroll="False"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         MinHeight="640">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0,0,12,12" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="260"
                                                    MinHeight="96"
                                                    Padding="14"
                                                    Background="#F7F9FB"
                                                    BorderBrush="#DCE5EC"
                                                    BorderThickness="1"
                                                    CornerRadius="16">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Nominativo}"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               Foreground="#17313E" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Text="{Binding CodiceFiscale}"
                                                               Foreground="#53646A" />
                                                    <TextBlock Margin="0,2,0,0"
                                                               Text="{Binding Contatti}"
                                                               Foreground="#53646A" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Servizio giornaliero">
                    <Grid Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="380" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Bozza modulo servizi"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="{Binding ServizioBozzaStato}"
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />

                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                        <Button Content="Nuovo servizio"
                                                Command="{Binding NewServizioCommand}" />
                                        <Button Content="Aggiorna personale"
                                                Command="{Binding ReloadServizioPersonaleCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,12,0,0"
                                    Style="{StaticResource CardStyle}"
                                    Background="#EEF4F8">
                                <StackPanel>
                                    <TextBlock Text="Sintesi operativa"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Background="#173A57"
                                                CornerRadius="16"
                                                Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="Partecipanti"
                                                           Foreground="#C9D7DA"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding ServizioPartecipantiTotali}"
                                                           Foreground="#FFF8EE"
                                                           FontSize="24"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2"
                                                Background="#CFA032"
                                                CornerRadius="16"
                                                Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="Presenti"
                                                           Foreground="#664B12"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding ServizioPresentiTotali}"
                                                           Foreground="#17313E"
                                                           FontSize="24"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Margin="0,10,0,0"
                                            Background="#F8FBFD"
                                            CornerRadius="16"
                                            Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Categoria registro"
                                                       Foreground="#53646A"
                                                       FontSize="12" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding ServizioCategoriaRegistroDescrizione}"
                                                       Foreground="#17313E"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,10,0,0"
                                            Background="#F8FBFD"
                                            CornerRadius="16"
                                            Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Tipo servizio"
                                                       Foreground="#53646A"
                                                       FontSize="12" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding ServizioTipoDescrizione}"
                                                       Foreground="#17313E"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding ServizioFuoriSedeDescrizione}"
                                                       Foreground="#53646A" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding ServizioImmersioniCompilate, StringFormat=Immersioni compilate: {0}/2}"
                                                       Foreground="#53646A" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <TextBlock Text="Servizio giornaliero"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="Prima schermata operativa del nuovo modulo. In questa fase puoi impostare la bozza del servizio, le immersioni e i partecipanti; il salvataggio definitivo verra collegato nel passo successivo."
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />

                                    <Border Margin="0,18,0,0"
                                            Background="#F2F5F8"
                                            CornerRadius="18"
                                            Padding="16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="170" />
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Data servizio" Foreground="#50626A" />
                                                <TextBox Text="{Binding ServizioData, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource DateTextBoxStyle}"
                                                         MaxLength="10"
                                                         ToolTip="Digita 25032026 oppure 25/03/2026"
                                                         infra:DateInputBehavior.AutoFormat="True" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Tipo servizio" Foreground="#50626A" />
                                                <ComboBox ItemsSource="{Binding TipiServizioDisponibili}"
                                                          SelectedItem="{Binding ServizioTipoSelezionato}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="Localita" Foreground="#50626A" />
                                                <ComboBox ItemsSource="{Binding LocalitaOperativeCatalogo}"
                                                          SelectedItem="{Binding ServizioLocalitaSelezionata}"
                                                          DisplayMemberPath="Descrizione" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                                <TextBlock Text="Unita navale" Foreground="#50626A" />
                                                <ComboBox ItemsSource="{Binding UnitaNavaliCatalogo}"
                                                          SelectedItem="{Binding ServizioUnitaNavaleSelezionata}"
                                                          DisplayMemberPath="Descrizione" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,10,0,0">
                                                <TextBlock Text="Fuori sede" Foreground="#50626A" />
                                                <CheckBox Margin="0,10,0,0"
                                                          IsChecked="{Binding ServizioFuoriSede}"
                                                          Content="Applica indennita fuori sede" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.Column="4" Margin="0,10,0,0">
                                                <TextBlock Text="Scopo immersione" Foreground="#50626A" />
                                                <ComboBox ItemsSource="{Binding ScopiImmersioneCatalogo}"
                                                          SelectedItem="{Binding ServizioScopoSelezionato}"
                                                          DisplayMemberPath="Descrizione" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" Grid.ColumnSpan="5" Margin="0,10,0,0">
                                                <TextBlock Text="Attivita svolta" Foreground="#50626A" />
                                                <TextBox Text="{Binding ServizioAttivitaSvolta, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap"
                                                         AcceptsReturn="True"
                                                         MinHeight="64" />
                                                <TextBlock Margin="0,10,0,0" Text="Note servizio" Foreground="#50626A" />
                                                <TextBox Text="{Binding ServizioNote, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap"
                                                         AcceptsReturn="True"
                                                         MinHeight="54" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <ItemsControl Margin="0,18,0,0"
                                                  ItemsSource="{Binding ServizioImmersioniBozza}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="520"
                                                        Margin="0,0,16,16"
                                                        Background="#F8FBFD"
                                                        BorderBrush="#D8E1E8"
                                                        BorderThickness="1"
                                                        CornerRadius="18"
                                                        Padding="16">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding NumeroImmersione, StringFormat=Immersione {0}}"
                                                                   FontSize="18"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#17313E" />

                                                        <Grid Margin="0,12,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="16" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel>
                                                                <TextBlock Text="Ora inizio" Foreground="#50626A" />
                                                                <TextBox Text="{Binding OrarioInizio, UpdateSourceTrigger=PropertyChanged}"
                                                                         Width="120"
                                                                         ToolTip="Formato consigliato: 08:30" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="Ora fine" Foreground="#50626A" />
                                                                <TextBox Text="{Binding OrarioFine, UpdateSourceTrigger=PropertyChanged}"
                                                                         Width="120"
                                                                         ToolTip="Formato consigliato: 10:15" />
                                                            </StackPanel>
                                                        </Grid>

                                                        <TextBlock Margin="0,10,0,0" Text="Direttore immersione" Foreground="#50626A" />
                                                        <ComboBox ItemsSource="{Binding DataContext.OperatoriServizioDisponibili, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding DirettoreImmersione}"
                                                                  DisplayMemberPath="NominativoConQualifica" />

                                                        <TextBlock Margin="0,10,0,0" Text="Operatore soccorso" Foreground="#50626A" />
                                                        <ComboBox ItemsSource="{Binding DataContext.OperatoriServizioDisponibili, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding OperatoreSoccorso}"
                                                                  DisplayMemberPath="NominativoConQualifica" />

                                                        <TextBlock Margin="0,10,0,0" Text="Assistenza BLSD" Foreground="#50626A" />
                                                        <ComboBox ItemsSource="{Binding DataContext.OperatoriServizioDisponibili, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding AssistenteBlsd}"
                                                                  DisplayMemberPath="NominativoConQualifica" />

                                                        <TextBlock Margin="0,10,0,0" Text="Assistenza sanitaria" Foreground="#50626A" />
                                                        <ComboBox ItemsSource="{Binding DataContext.OperatoriServizioDisponibili, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding AssistenteSanitario}"
                                                                  DisplayMemberPath="NominativoConQualifica" />

                                                        <TextBlock Margin="0,10,0,0" Text="Note immersione" Foreground="#50626A" />
                                                        <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                                                 TextWrapping="Wrap"
                                                                 AcceptsReturn="True"
                                                                 MinHeight="48" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="Personale impiegato"
                                               FontSize="19"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="In questa fase il personale e gestito in una griglia unica: scegli gruppo operativo, presenza e ruolo. E piu flessibile del modello Word e si presta meglio ai conteggi futuri."
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />

                                    <DataGrid Margin="0,16,0,0"
                                              ItemsSource="{Binding ServizioPartecipantiBozza}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              MinHeight="360"
                                              HeadersVisibility="Column"
                                              RowHeaderWidth="0"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Qualifica"
                                                                Width="120"
                                                                Binding="{Binding Qualifica}" />
                                            <DataGridTextColumn Header="Cognome e nome"
                                                                Width="220"
                                                                Binding="{Binding Nominativo}" />
                                            <DataGridCheckBoxColumn Header="Presente"
                                                                    Width="90"
                                                                    Binding="{Binding Presente, UpdateSourceTrigger=PropertyChanged}" />
