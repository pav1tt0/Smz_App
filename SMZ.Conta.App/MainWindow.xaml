                                            </DockPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,10,0,0">
                                            <TextBlock Text="Mail personale" Foreground="#50626A" />
                                            <TextBox Text="{Binding Mail2Utente, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="Inserisci l'indirizzo completo" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                            <TextBlock Text="Via" Foreground="#50626A" />
                                            <TextBox Text="{Binding ViaResidenza, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <Grid Grid.Row="2" Grid.Column="2" Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="CAP" Foreground="#50626A" />
                                                <TextBox Text="{Binding CapResidenza, UpdateSourceTrigger=PropertyChanged}"
                                                         MaxLength="5" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Citta" Foreground="#50626A" />
                                                <TextBox Text="{Binding CittaResidenza, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </StackPanel>

                        </Border>
                        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                            <TabControl Background="Transparent"
                                        BorderThickness="0"
                                        SelectedIndex="{Binding SchedaDettaglioTabIndex}">
                                <TabItem Header="Abilitazioni">
                                    <Grid Margin="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="16" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Border Background="#F3F6FA" CornerRadius="18" Padding="16">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="Inserimento guidato abilitazione"
                                                           FontSize="19"
                                                           FontWeight="SemiBold"
                                                           Foreground="#17313E" />

                                                <Grid Grid.Row="1" Margin="0,14,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.2*" />
                                                        <ColumnDefinition Width="18" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="Tipo abilitazione" Foreground="#50626A" />
