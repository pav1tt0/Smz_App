<Window x:Class="SMZ.Conta.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:infra="clr-namespace:SMZ.Conta.App.Infrastructure"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Titolo}"
        Width="1660"
        Height="960"
        MinWidth="1460"
        MinHeight="780"
        WindowState="Maximized"
        Background="#0A1628"
        FontFamily="Bahnschrift">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFCF7"/>
            <Setter Property="BorderBrush" Value="#D8E1E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#C9D5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="DateTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="150"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="HiddenTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <ContentPresenter ContentSource="SelectedContent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#E6EDF5"/>
            <Setter Property="BorderBrush" Value="#CFDAE5"/>
            <Setter Property="Foreground" Value="#4B6175"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12,12,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#F0F5FA"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#143A63"/>
                                <Setter TargetName="TabBorder" Property="Background" Value="#FFFCF7"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#C9D8E7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TabBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="MinWidth" Value="132"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#174E78"/>
            <Setter Property="Foreground" Value="#FFFDF7"/>
            <Setter Property="BorderBrush" Value="#174E78"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.48"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}" />

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#DFE8F1"/>
            <Setter Property="BorderBrush" Value="#DFE8F1"/>
            <Setter Property="Foreground" Value="#17313E"/>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#CFA032"/>
            <Setter Property="BorderBrush" Value="#CFA032"/>
            <Setter Property="Foreground" Value="#17313E"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#8F3434"/>
            <Setter Property="BorderBrush" Value="#8F3434"/>
            <Setter Property="Foreground" Value="#FFF7F3"/>
        </Style>

        <Style x:Key="HomeCardButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#C7D5E2"/>
            <Setter Property="Foreground" Value="#0F2E47"/>
            <Setter Property="MinWidth" Value="240"/>
            <Setter Property="MinHeight" Value="128"/>
            <Setter Property="Padding" Value="22,18"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="CardBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1.2"
                                    CornerRadius="26"
                                    SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="24"
                                                      ShadowDepth="8"
                                                      Direction="270"
                                                      Opacity="0.18"
                                                      Color="#15314A" />
                                </Border.Effect>
                            </Border>

                            <Border x:Name="AccentBar"
                                    Height="8"
                                    Margin="18,16,18,0"
                                    VerticalAlignment="Top"
                                    Background="{TemplateBinding BorderBrush}"
                                    CornerRadius="999" />

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#8EA9BE" />
                                <Setter TargetName="CardBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="30"
                                                          ShadowDepth="12"
                                                          Direction="270"
                                                          Opacity="0.28"
                                                          Color="#173A57" />
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="-4" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="-1" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CardBorder" Property="Opacity" Value="0.55" />
                                <Setter TargetName="AccentBar" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HomeMiniCardButtonStyle" TargetType="Button" BasedOn="{StaticResource HomeCardButtonStyle}">
            <Setter Property="MinWidth" Value="220"/>
            <Setter Property="MinHeight" Value="120"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <Style x:Key="HomeSectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4F73A5"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="HomeDarkPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="#0F2040"/>
            <Setter Property="BorderBrush" Value="#1E3860"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="HeaderHomeButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="#F5FAFF"/>
            <Setter Property="BorderBrush" Value="#7FA8DA"/>
            <Setter Property="Foreground" Value="#10274B"/>
            <Setter Property="MinWidth" Value="118"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsHomeSection}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <ImageBrush x:Key="HomePhotoBrush"
                    ImageSource="Assets/smz.jpg"
                    Stretch="UniformToFill" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="#2A5298"
                BorderThickness="1.4"
                CornerRadius="22"
                Padding="20"
                Margin="0,0,0,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0D2040" Offset="0" />
                    <GradientStop Color="#1A3A6B" Offset="0.52" />
                    <GradientStop Color="#0D2040" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <Image Width="124"
                       Height="94"
                       Source="Assets/logo_smz.png"
                       Stretch="Uniform"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="POLIZIA DI STATO"
                            FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="#D7E5F7"
                               HorizontalAlignment="Center" />
                    <TextBlock Margin="0,4,0,0"
                               Text="NUCLEO SOMMOZZATORI"
                               FontSize="21"
                               Foreground="#7FA8DA"
                               HorizontalAlignment="Center" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Gestione operativa di servizi giornalieri, personale e contabilita"
                               FontSize="13"
                               Foreground="#5F8CCC"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <Grid Grid.Column="2" Margin="24,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="← Home"
                                Command="{Binding NavigateSectionCommand}"
                                CommandParameter="0"
                                ToolTip="Torna alla schermata iniziale"
                                Style="{StaticResource HeaderHomeButtonStyle}" />
                    </StackPanel>

                    <Border Grid.Row="2"
                            Height="94"
                            CornerRadius="18"
                            BorderBrush="#284A78"
                            BorderThickness="1.2"
                            Background="{StaticResource HomePhotoBrush}"
                            VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <TabControl SelectedIndex="{Binding SezioneAttivaIndex}"
                        Style="{StaticResource HiddenTabControlStyle}">
                <TabItem Header="Home">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="28" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="MODULI PRINCIPALI"
                                       Style="{StaticResource HomeSectionLabelStyle}" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="Accesso diretto alle aree usate ogni giorno dal nucleo."
                                       FontSize="14"
                                       Foreground="#A7C0DF" />
                        </StackPanel>

                        <Border Grid.Row="2"
                                Style="{StaticResource HomeDarkPanelStyle}"
                                Padding="22">
                            <UniformGrid Columns="5">
                                <Button Margin="0,0,18,0"
                                    Command="{Binding NavigateSectionCommand}"
                                    CommandParameter="2"
                                    Background="#F6FAFF"
                                    BorderBrush="#5B84BD"
                                    Foreground="#10274B"
                                    Style="{StaticResource HomeCardButtonStyle}">
                                    <StackPanel>
                                        <TextBlock Text="SERVIZIO"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="GIORNALIERO"
                                                   Margin="0,4,0,0"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Margin="0,0,18,0"
                                    Command="{Binding NavigateSectionCommand}"
                                    CommandParameter="3"
                                    Background="#F8FBFD"
                                    BorderBrush="#7A94AC"
                                    Foreground="#10274B"
                                    Style="{StaticResource HomeCardButtonStyle}">
                                    <StackPanel>
                                        <TextBlock Text="ANAGRAFICA"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="PERSONALE"
                                                   Margin="0,4,0,0"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Margin="0,0,18,0"
                                    Command="{Binding NavigateSectionCommand}"
                                    CommandParameter="5"
                                    Background="#F4FAFF"
                                    BorderBrush="#3E7AA6"
                                    Foreground="#10274B"
                                    Style="{StaticResource HomeCardButtonStyle}">
                                    <StackPanel>
                                        <TextBlock Text="CONTABILITA'"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Margin="0,0,18,0"
                                    Command="{Binding NavigateSectionCommand}"
                                    CommandParameter="6"
                                    Background="#FBF8F1"
                                    BorderBrush="#A77D3E"
                                    Foreground="#10274B"
                                    Style="{StaticResource HomeCardButtonStyle}">
                                    <StackPanel>
                                        <TextBlock Text="STAMPE"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="E REPORT"
                                                   Margin="0,4,0,0"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding NavigateSectionCommand}"
                                    CommandParameter="4"
                                    Background="#F7FBF8"
                                    BorderBrush="#6F8F77"
                                    Foreground="#10274B"
                                    Style="{StaticResource HomeCardButtonStyle}">
                                    <StackPanel>
                                        <TextBlock Text="ARCHIVIO"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="SCHEDE"
                                                   Margin="0,4,0,0"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </UniformGrid>
                        </Border>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300" />
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="RICERCA RAPIDA"
                                           Style="{StaticResource HomeSectionLabelStyle}" />
                                <Border Margin="0,10,0,0"
                                        Style="{StaticResource HomeDarkPanelStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Consultazione rapida del personale e delle scadenze."
                                                   Foreground="#9AB4D5"
                                                   TextWrapping="Wrap" />

                                        <Button Margin="0,16,0,0"
                                                Command="{Binding NavigateSectionCommand}"
                                                CommandParameter="1"
                                                Background="#F7FBFF"
                                                BorderBrush="#5B84BD"
                                                Foreground="#10274B"
                                                Style="{StaticResource HomeCardButtonStyle}">
                                            <StackPanel>
                                                <TextBlock Text="RICERCA"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="DASHBOARD OPERATIVA"
                                           Style="{StaticResource HomeSectionLabelStyle}" />
                                <Border Margin="0,10,0,0"
                                        Style="{StaticResource HomeDarkPanelStyle}"
                                        Padding="22">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="18" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="18" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="{Binding DashboardStatoSintesi}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="#D7E5F7" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding DashboardScadenzeSintesi}"
                                                   Foreground="#4F73A5"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <UniformGrid Grid.Row="2"
                                                 Columns="2">
                                        <Button Margin="0,0,14,0"
                                                Command="{Binding NavigateSectionCommand}"
                                                CommandParameter="1"
                                                Background="#F8FAFD"
                                                BorderBrush="#A64A4A"
                                                Foreground="#10274B"
                                                Style="{StaticResource HomeMiniCardButtonStyle}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DashboardVisiteScadutePersonale}"
                                                           FontSize="40"
                                                           FontWeight="SemiBold"
                                                           Foreground="#C84848"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Margin="0,10,0,0"
                                                           Text="VISITE MEDICHE"
                                                           TextAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Text="SCADUTE"
                                                           TextAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>

                                        <Button Command="{Binding NavigateSectionCommand}"
                                                CommandParameter="1"
                                                Background="#FBF9F2"
                                                BorderBrush="#B17A26"
                                                Foreground="#10274B"
                                                Style="{StaticResource HomeMiniCardButtonStyle}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DashboardVisiteInScadenzaPersonale}"
                                                           FontSize="40"
                                                           FontWeight="SemiBold"
                                                           Foreground="#B17A26"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Margin="0,10,0,0"
                                                           Text="VISITE MEDICHE"
                                                           TextAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Text="IN SCADENZA"
                                                           TextAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </UniformGrid>

                                    <StackPanel Grid.Row="4">
                                        <TextBlock Text="PERSONALE CON CRITICITA'"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#7FA8DA" />
                                        <ItemsControl Margin="0,12,0,0"
                                                      ItemsSource="{Binding DashboardCriticitaItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8"
                                                            Height="82"
                                                            Background="#12284C"
                                                            BorderBrush="#24406B"
                                                            BorderThickness="1"
                                                            CornerRadius="10"
                                                            Padding="10,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="1.25*" />
                                                                <ColumnDefinition Width="14" />
                                                                <ColumnDefinition Width="1*" />
                                                                <ColumnDefinition Width="14" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding Nominativo}"
                                                                       Foreground="#E4EEF9"
                                                                       FontSize="16"
                                                                       FontWeight="SemiBold"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis" />

                                                            <StackPanel Grid.Column="2"
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Titolo}"
                                                                           Foreground="#D7E5F7"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold"
                                                                           TextAlignment="Right"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding CriticitaDataText}"
                                                                           Foreground="#BFD2EA"
                                                                           FontSize="12"
                                                                           TextAlignment="Right"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>

                                                            <Border Grid.Column="4"
                                                                    Padding="12,6"
                                                                    CornerRadius="6"
                                                                    VerticalAlignment="Center">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="#D1A344" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsExpired}" Value="True">
                                                                                <Setter Property="Background" Value="#B94141" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding CriticitaBadgeText}"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="#5B430F" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsExpired}" Value="True">
                                                                                    <Setter Property="Foreground" Value="#FFF7F3" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Ricerca">
                    <Grid Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="390" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Ricerca personale"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />

                                    <TextBlock Margin="0,14,0,0" Text="Cognome o nome" Foreground="#50626A" />
                                    <TextBox Text="{Binding FiltroCognome, UpdateSourceTrigger=PropertyChanged}" />

                                    <Border Margin="0,8,0,0"
                                            Padding="8"
                                            Background="#F4F7F3"
                                            BorderBrush="#D2DBD6"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Visibility="{Binding IsSearchSuggestionsOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ListBox ItemsSource="{Binding SearchSuggestions}"
                                                 SelectedItem="{Binding SelectedSearchSuggestion}"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 MaxHeight="120"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                    </Border>

                                    <TextBlock Margin="0,12,0,0" Text="Abilitazione" Foreground="#50626A" />
                                    <ComboBox ItemsSource="{Binding FiltroAbilitazioni}"
