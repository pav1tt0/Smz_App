                                                       Text="{Binding SchedaRiepilogoTitolo}"
                                                       Foreground="#FFF8EE"
                                                       FontSize="22"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding SchedaRiepilogoPerId}"
                                                       Foreground="#D9E4E7" />
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                                Background="#24527B"
                                                CornerRadius="18"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Abilitazioni principali"
                                                           Foreground="#CBDBE0"
                                                           FontSize="12" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding SchedaAbilitazioniPrincipali}"
                                                           Foreground="#FFF8EE"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="{Binding SchedaAbilitazioniPrincipaliFooter}"
                                                           Foreground="#CBDBE0"
                                                           FontSize="12" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="4"
                                                Background="#F4F7F3"
                                                CornerRadius="18"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Prossima scadenza"
                                                           Foreground="#50626A"
                                                           FontSize="12" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding SchedaProssimaScadenza}"
                                                           Foreground="#17313E"
                                                           FontSize="22"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding SchedaProssimaScadenzaDettaglio}"
                                                           Foreground="#52656B"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="6"
                                                CornerRadius="18"
                                                Padding="14">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#EEF2F4" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SchedaHaScadute}" Value="True">
                                                            <Setter Property="Background" Value="#FBEAEA" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="{Binding SchedaScaduteTitolo}"
                                                           FontSize="12">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#53646A" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SchedaHaScadute}" Value="True">
                                                                    <Setter Property="Foreground" Value="#8B2E2E" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding SchedaScaduteHighlight}"
