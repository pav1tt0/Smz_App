                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                            <TextBlock Text="Via" Foreground="#50626A" />
                                            <TextBox Text="{Binding ViaResidenza, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <Grid Grid.Row="2" Grid.Column="2" Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="CAP" Foreground="#50626A" />
                                                <TextBox Text="{Binding CapResidenza, UpdateSourceTrigger=PropertyChanged}"
                                                         MaxLength="5" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Citta" Foreground="#50626A" />
                                                <TextBox Text="{Binding CittaResidenza, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </StackPanel>

                        </Border>
                        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                            <TabControl Background="Transparent"
                                        BorderThickness="0"
                                        SelectedIndex="{Binding SchedaDettaglioTabIndex}">
                                <TabItem Header="Abilitazioni">
                                    <Grid Margin="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="16" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Border Background="#F3F6FA" CornerRadius="18" Padding="16">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="Inserimento guidato abilitazione"
                                                           FontSize="19"
                                                           FontWeight="SemiBold"
                                                           Foreground="#17313E" />

                                                <Grid Grid.Row="1" Margin="0,14,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.2*" />
                                                        <ColumnDefinition Width="18" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="Tipo abilitazione" Foreground="#50626A" />
                                                        <ComboBox ItemsSource="{Binding TipiAbilitazioneCatalogo}"
                                                                  SelectedItem="{Binding AbilitazioneTipoSelezionato}"
                                                                  DisplayMemberPath="EtichettaCompleta" />

                                                        <TextBlock Margin="0,10,0,0" Text="{Binding AbilitazioneLivelloEtichetta}" Foreground="#50626A" />
                                                        <ComboBox ItemsSource="{Binding AbilitazioneLivelliSuggeriti}"
                                                                  Text="{Binding AbilitazioneLivello, UpdateSourceTrigger=PropertyChanged}"
                                                                  IsEnabled="{Binding AbilitazioneRichiedeLivello}"
                                                                  IsEditable="True"
                                                                  IsTextSearchEnabled="False"
                                                                  ToolTip="Per la patente di guida seleziona un certificato da 1 a 5" />

                                                        <TextBlock Margin="0,10,0,0" Text="Profondita metri" Foreground="#50626A" />
                                                        <ComboBox ItemsSource="{Binding AbilitazioneProfonditaSuggerite}"
                                                                  Text="{Binding AbilitazioneProfondita, UpdateSourceTrigger=PropertyChanged}"
                                                                  IsEnabled="{Binding AbilitazioneRichiedeProfondita}"
                                                                  IsEditable="True"
                                                                  IsTextSearchEnabled="False"
                                                                  ToolTip="Seleziona una profondita suggerita oppure digita un valore personalizzato" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Data conseguimento" Foreground="#50626A" />
                                                        <TextBox Text="{Binding AbilitazioneDataConseguimento, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource DateTextBoxStyle}"
                                                                 MaxLength="10"
                                                                 ToolTip="Digita 18032026 oppure 18/03/2026"
                                                                 infra:DateInputBehavior.AutoFormat="True" />

                                                        <TextBlock Margin="0,10,0,0" Text="Data scadenza" Foreground="#50626A" />
                                                        <TextBox Text="{Binding AbilitazioneDataScadenza, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource DateTextBoxStyle}"
                                                                 MaxLength="10"
                                                                 ToolTip="Digita 18032026 oppure 18/03/2026"
                                                                 infra:DateInputBehavior.AutoFormat="True"
                                                                 IsEnabled="{Binding AbilitazioneRichiedeScadenza}" />

                                                        <TextBlock Margin="0,10,0,0" Text="Note" Foreground="#50626A" />
                                                        <TextBox Text="{Binding AbilitazioneNote, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Grid.Row="2" Margin="0,16,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{Binding AbilitazioneIndicazioni}"
                                                               Foreground="#5B6C72"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap" />

                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="18,0,0,0">
                                                        <Button Content="{Binding AzioneAbilitazioneLabel}"
                                                                Command="{Binding SaveAbilitazioneCommand}" />
                                                        <Button Content="Pulisci editor"
                                                                Command="{Binding ClearAbilitazioneEditorCommand}"
                                                                Style="{StaticResource SecondaryButtonStyle}" />
                                                        <Button Content="Rimuovi selezionata"
                                                                Command="{Binding RemoveAbilitazioneCommand}"
                                                                Style="{StaticResource DangerButtonStyle}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <DataGrid Grid.Row="2"
                                                  ItemsSource="{Binding Abilitazioni}"
                                                  SelectedItem="{Binding SelectedAbilitazione}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  IsReadOnly="True"
                                                  MinHeight="260"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  HeadersVisibility="Column"
                                                  RowHeaderWidth="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Tipo"
                                                                    Width="230"
                                                                    Binding="{Binding TipoDescrizione}" />
                                                <DataGridTextColumn Header="Categoria"
                                                                    Width="120"
                                                                    Binding="{Binding Categoria}" />
                                                <DataGridTextColumn Header="Livello"
                                                                    Width="120"
                                                                    Binding="{Binding Livello}" />
                                                <DataGridTextColumn Header="Profondita"
                                                                    Width="95"
                                                                    Binding="{Binding ProfonditaMetri}" />
                                                <DataGridTextColumn Header="Conseguimento"
                                                                    Width="120"
                                                                    Binding="{Binding DataConseguimento}" />
                                                <DataGridTextColumn Header="Scadenza"
                                                                    Width="120"
                                                                    Binding="{Binding DataScadenza}" />
                                                <DataGridTextColumn Header="Note"
                                                                    Width="*"
                                                                    Binding="{Binding Note}" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </TabItem>

                                <TabItem Header="Visite mediche">
                                    <Grid Margin="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="16" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Border Background="#F3F6FA" CornerRadius="18" Padding="16">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="Visite mediche obbligatorie"
                                                           FontSize="19"
                                                           FontWeight="SemiBold"
                                                           Foreground="#17313E" />

                                                <Grid Grid.Row="1" Margin="0,14,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.2*" />
                                                        <ColumnDefinition Width="18" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="Tipo visita" Foreground="#50626A" />
                                                        <ComboBox ItemsSource="{Binding TipiVisitaMedicaCatalogo}"
                                                                  SelectedItem="{Binding VisitaTipoSelezionato}"
                                                                  DisplayMemberPath="Descrizione" />

                                                        <TextBlock Margin="0,10,0,0" Text="Data ultima visita" Foreground="#50626A" />
                                                        <TextBox Text="{Binding VisitaDataUltimaVisita, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource DateTextBoxStyle}"
                                                                 MaxLength="10"
                                                                 ToolTip="Digita 18032026 oppure 18/03/2026"
                                                                 infra:DateInputBehavior.AutoFormat="True" />

                                                        <TextBlock Margin="0,10,0,0" Text="Esito" Foreground="#50626A" />
                                                        <TextBox Text="{Binding VisitaEsito, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="{Binding RegoleVisiteTitolo}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#17313E" />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Text="{Binding RegoleVisiteDescrizione}"
                                                                   Foreground="#53646A"
                                                                   TextWrapping="Wrap" />

                                                        <TextBlock Margin="0,12,0,0" Text="Scadenza calcolata" Foreground="#50626A" />
                                                        <TextBox Text="{Binding VisitaScadenzaCalcolata, Mode=OneWay}"
                                                                 Style="{StaticResource DateTextBoxStyle}"
                                                                 IsReadOnly="True"
                                                                 IsReadOnlyCaretVisible="False"
                                                                 Background="#F6F8F6" />

                                                        <TextBlock Margin="0,10,0,0" Text="Note" Foreground="#50626A" />
                                                        <TextBox Text="{Binding VisitaNote, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Grid.Row="2" Margin="0,16,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{Binding VisitaIndicazioni}"
                                                               Foreground="#5B6C72"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap" />

                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="18,0,0,0">
                                                        <Button Content="{Binding AzioneVisitaLabel}"
                                                                Command="{Binding SaveVisitaCommand}" />
                                                        <Button Content="Ricarica visita"
                                                                Command="{Binding ClearVisitaEditorCommand}"
                                                                Style="{StaticResource SecondaryButtonStyle}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <DataGrid Grid.Row="2"
                                                  ItemsSource="{Binding VisiteMediche}"
                                                  SelectedItem="{Binding SelectedVisita}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  IsReadOnly="True"
                                                  MinHeight="260"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  HeadersVisibility="Column"
                                                  RowHeaderWidth="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Tipo visita"
                                                                    Width="280"
                                                                    Binding="{Binding TipoVisita}" />
                                                <DataGridTextColumn Header="Ultima visita"
                                                                    Width="130"
                                                                    Binding="{Binding DataUltimaVisita}" />
                                                <DataGridTextColumn Header="Scadenza"
                                                                    Width="150"
                                                                    Binding="{Binding DataScadenza}" />
                                                <DataGridTextColumn Header="Esito"
                                                                    Width="150"
                                                                    Binding="{Binding Esito}" />
                                                <DataGridTextColumn Header="Note"
                                                                    Width="*"
                                                                    Binding="{Binding Note}" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Archivio">
                    <Grid Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="390" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Schede eliminate recuperabili"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#17313E" />

                                <TextBlock Grid.Row="1"
                                           Margin="0,12,0,0"
                                           Text="Qui trovi solo le schede gia eliminate dalla parte operativa ma ancora recuperabili prima della rimozione definitiva."
                                           Foreground="#53646A"
                                           TextWrapping="Wrap" />

                                <ListBox Grid.Row="2"
                                         Margin="0,16,0,0"
                                         ItemsSource="{Binding ArchivioItems}"
                                         SelectedItem="{Binding SelectedArchivio}"
                                         MaxHeight="640"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.CanContentScroll="False"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         MinHeight="640">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10"
                                                    Padding="14"
                                                    Background="#F2F5F0"
                                                    CornerRadius="16">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Nominativo}"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               Foreground="#17313E" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Text="{Binding PerIdOriginaleLabel}"
                                                               Foreground="#53646A" />
                                                    <TextBlock Margin="0,2,0,0"
                                                               Text="{Binding CodiceFiscale}"
                                                               Foreground="#53646A" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Text="{Binding DataArchiviazioneLabel}"
                                                               Foreground="#6A7B80"
                                                               FontSize="12" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="{Binding ArchivioTitolo}"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Foreground="#17313E" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding ArchivioPerId}"
                                                   Foreground="#53646A" />
                                    </StackPanel>

                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="Ripristina scheda"
                                                Command="{Binding RestoreArchivioCommand}" />
                                        <Button Content="Elimina in modo definitivo"
                                                Command="{Binding DeleteArchivioDefinitivoCommand}"
                                                Style="{StaticResource DangerButtonStyle}" />
                                    </StackPanel>
                                </DockPanel>

                                <TextBlock Grid.Row="1"
                                           Margin="0,12,0,0"
                                           Text="Ripristina per riportare la scheda tra i dipendenti attivi. Usa l'eliminazione definitiva solo quando non serve piu alcun recupero."
                                           Foreground="#53646A"
                                           TextWrapping="Wrap" />

                                <Grid Grid.Row="2" Margin="0,18,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="16" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="16" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Border Background="#EEF4EE"
                                            CornerRadius="18"
                                            Padding="16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.2*" />
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Dettaglio archivio"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="#17313E" />
                                                <TextBlock Margin="0,12,0,0"
                                                           Text="{Binding ArchivioCodiceFiscale}"
                                                           Foreground="#17313E"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding ArchivioContatti}"
                                                           Foreground="#53646A"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding ArchivioDataArchiviazione}"
                                                           Foreground="#6A7B80" />
                                            </StackPanel>

                                            <Grid Grid.Column="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Background="#17313E"
                                                        CornerRadius="16"
                                                        Padding="12">
                                                    <StackPanel>
                                                        <TextBlock Text="Abilitazioni"
                                                                   Foreground="#C9D7DA"
                                                                   FontSize="13" />
                                                        <TextBlock Text="{Binding ArchivioAbilitazioniTotali}"
                                                                   Foreground="#FFF8EE"
                                                                   FontSize="24"
                                                                   FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="2"
                                                        Background="#DFE8F1"
                                                        CornerRadius="16"
                                                        Padding="12">
                                                    <StackPanel>
                                                        <TextBlock Text="Visite mediche"
                                                                   Foreground="#53646A"
                                                                   FontSize="13" />
                                                        <TextBlock Text="{Binding ArchivioVisiteTotali}"
                                                                   Foreground="#17313E"
                                                                   FontSize="24"
                                                                   FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="2"
                                            Background="#FFFCF7"
                                            CornerRadius="18"
                                            Padding="16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="Anagrafica archiviata"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="#17313E" />
                                            <TextBlock Grid.Row="1"
                                                       Margin="0,10,0,0"
                                                       Text="{Binding ArchivioAnagraficaSintesi}"
                                                       Foreground="#53646A"
                                                       TextWrapping="Wrap" />

                                            <DataGrid Grid.Row="2"
                                                      Margin="0,16,0,0"
                                                      ItemsSource="{Binding ArchivioAbilitazioni}"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      MinHeight="220"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                      HeadersVisibility="Column"
                                                      RowHeaderWidth="0">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Tipo"
                                                                        Width="220"
                                                                        Binding="{Binding TipoDescrizione}" />
                                                    <DataGridTextColumn Header="Categoria"
                                                                        Width="120"
                                                                        Binding="{Binding Categoria}" />
                                                    <DataGridTextColumn Header="Livello"
                                                                        Width="110"
                                                                        Binding="{Binding Livello}" />
                                                    <DataGridTextColumn Header="Profondita"
                                                                        Width="95"
                                                                        Binding="{Binding ProfonditaMetri}" />
                                                    <DataGridTextColumn Header="Conseguimento"
                                                                        Width="120"
                                                                        Binding="{Binding DataConseguimento}" />
                                                    <DataGridTextColumn Header="Scadenza"
                                                                        Width="120"
                                                                        Binding="{Binding DataScadenza}" />
                                                    <DataGridTextColumn Header="Note"
                                                                        Width="*"
                                                                        Binding="{Binding Note}" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="4"
                                            Background="#FFFCF7"
                                            CornerRadius="18"
                                            Padding="16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="Visite mediche archiviate"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="#17313E" />

                                            <DataGrid Grid.Row="1"
                                                      Margin="0,16,0,0"
                                                      ItemsSource="{Binding ArchivioVisiteMediche}"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      MinHeight="220"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                      HeadersVisibility="Column"
                                                      RowHeaderWidth="0">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Tipo visita"
                                                                        Width="280"
                                                                        Binding="{Binding TipoVisita}" />
                                                    <DataGridTextColumn Header="Ultima visita"
                                                                        Width="130"
                                                                        Binding="{Binding DataUltimaVisita}" />
                                                    <DataGridTextColumn Header="Scadenza"
                                                                        Width="150"
                                                                        Binding="{Binding DataScadenza}" />
                                                    <DataGridTextColumn Header="Esito"
                                                                        Width="150"
                                                                        Binding="{Binding Esito}" />
                                                    <DataGridTextColumn Header="Note"
                                                                        Width="*"
                                                                        Binding="{Binding Note}" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Contabilita">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{Binding ContabilitaPeriodoTitolo}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="Modulo contabile operativo: riepilogo SMZ immersioni, piu giornate utili e trentesimi per sanitari e supporto occasionale."
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <StackPanel Width="170">
                                        <TextBlock Text="Mese"
                                                   Foreground="#50626A" />
                                        <ComboBox ItemsSource="{Binding ContabilitaMesiDisponibili}"
                                                  SelectedItem="{Binding ContabilitaMeseSelezionato}"
                                                  DisplayMemberPath="Descrizione" />
                                    </StackPanel>

                                    <StackPanel Width="110"
                                                Margin="12,0,0,0">
                                        <TextBlock Text="Anno"
                                                   Foreground="#50626A" />
                                        <ComboBox ItemsSource="{Binding ContabilitaAnniDisponibili}"
                                                  SelectedItem="{Binding ContabilitaAnnoSelezionato}" />
                                    </StackPanel>

                                    <Button Margin="12,20,0,0"
                                            Content="Aggiorna"
                                            Command="{Binding ReloadContabilitaCommand}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="Contabilita SMZ immersioni"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="#17313E" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding ContabilitaSmzStato}"
                                                   Foreground="#53646A"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Button DockPanel.Dock="Right"
                                            Content="{Binding ToggleTariffeContabiliLabel}"
                                            Command="{Binding ToggleTariffeContabiliCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </DockPanel>

                                <TextBlock Grid.Row="1"
                                           Margin="0,14,0,0"
                                           Text="Le righe sono separate per data e ordine di servizio, cosi puoi risalire subito all'origine operativa della contabilita."
                                           Foreground="#6A7B80"
                                           TextWrapping="Wrap" />

                                <DataGrid Grid.Row="2"
                                          Margin="0,16,0,0"
                                          ItemsSource="{Binding ContabilitaSmzItems}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          RowHeaderWidth="0"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Data"
                                                            Width="95"
                                                            Binding="{Binding DataServizioDescrizione}" />
                                        <DataGridTextColumn Header="Ordine"
                                                            Width="120"
                                                            Binding="{Binding NumeroOrdineServizio}" />
                                        <DataGridTextColumn Header="PerID"
                                                            Width="80"
                                                            Binding="{Binding PerId}" />
                                        <DataGridTextColumn Header="Qual."
                                                            Width="110"
                                                            Binding="{Binding Qualifica}" />
                                        <DataGridTextColumn Header="Cognome e nome"
                                                            Width="220"
                                                            Binding="{Binding Nominativo}" />
                                        <DataGridTextColumn Header="Appar."
                                                            Width="95"
                                                            Binding="{Binding Apparato}" />
                                        <DataGridTextColumn Header="Prof."
                                                            Width="80"
                                                            Binding="{Binding FasciaProfondita}" />
                                        <DataGridTextColumn Header="Tariffa"
                                                            Width="75"
                                                            Binding="{Binding TariffaDisplay}" />
                                        <DataGridTextColumn Header="ORE ORD"
                                                            Width="80"
                                                            Binding="{Binding OreOrdDisplay}" />
                                        <DataGridTextColumn Header="ORE ADD"
                                                            Width="80"
                                                            Binding="{Binding OreAddDisplay}" />
                                        <DataGridTextColumn Header="ORE SPER"
                                                            Width="85"
                                                            Binding="{Binding OreSperDisplay}" />
                                        <DataGridTextColumn Header="ORE C.I."
                                                            Width="80"
                                                            Binding="{Binding OreCiDisplay}" />
                                        <DataGridTextColumn Header="Importo"
                                                            Width="90"
                                                            Binding="{Binding ImportoDisplay}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="4"
                                Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="Tariffe contabili"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="#17313E" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding TariffeContabiliStato}"
                                                   Foreground="#53646A"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Button DockPanel.Dock="Right"
                                            Content="Salva tariffe"
                                            Command="{Binding SaveTariffeContabiliCommand}" />
                                </DockPanel>

                                <TextBlock Grid.Row="1"
                                           Margin="0,12,0,0"
                                           Text="Qui puoi adeguare le tariffe del prospetto contabile senza modificare il codice. I valori salvati restano nel database e vengono usati nei calcoli successivi."
                                           Foreground="#6A7B80"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding MostraTariffeContabili, Converter={StaticResource BoolToVisibilityConverter}}" />

                                <DataGrid Grid.Row="2"
                                          Margin="0,16,0,0"
                                          ItemsSource="{Binding RegoleContabiliEditorItems}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column"
                                          RowHeaderWidth="0"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          MinHeight="260"
                                          Visibility="{Binding MostraTariffeContabili, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Apparato"
                                                            Width="140"
                                                            Binding="{Binding TipologiaDescrizione}" />
                                        <DataGridTextColumn Header="Fascia"
                                                            Width="90"
                                                            Binding="{Binding FasciaDescrizione}" />
                                        <DataGridTextColumn Header="Categoria"
                                                            Width="110"
                                                            Binding="{Binding CategoriaDescrizione}" />
                                        <DataGridTextColumn Header="Tariffa"
                                                            Width="100"
                                                            Binding="{Binding Tariffa, UpdateSourceTrigger=PropertyChanged}" />
                                        <DataGridCheckBoxColumn Header="Attiva"
                                                                Width="80"
                                                                Binding="{Binding Attiva, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Sanitari impiegati"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <TextBlock Grid.Row="1"
                                               Margin="0,10,0,0"
                                               Text="{Binding ContabilitaSanitariStato}"
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />

                                    <DataGrid Grid.Row="2"
                                              Margin="0,16,0,0"
                                              ItemsSource="{Binding ContabilitaSanitariItems}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              RowHeaderWidth="0"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="PerID"
                                                                Width="80"
                                                                Binding="{Binding PerId}" />
                                            <DataGridTextColumn Header="Nominativo"
                                                                Width="220"
                                                                Binding="{Binding Nominativo}" />
                                            <DataGridTextColumn Header="Qualifica / ruolo"
                                                                Width="200"
                                                                Binding="{Binding QualificaConRuolo}" />
                                            <DataGridTextColumn Header="Giornate"
                                                                Width="90"
                                                                Binding="{Binding GiornateImpiego}" />
                                            <DataGridTextColumn Header="Trentesimi"
                                                                Width="90"
                                                                Binding="{Binding TrentesimiMaturati}" />
                                            <DataGridTextColumn Header="Ultimo servizio"
                                                                Width="120"
                                                                Binding="{Binding UltimaDataServizioDescrizione}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Supporto occasionale"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <StackPanel Grid.Row="1"
                                                Margin="0,10,0,0">
                                        <TextBlock Text="{Binding ContabilitaSupportoStato}"
                                                   Foreground="#53646A"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="Aggregazione per nominativo: conviene usare sempre la stessa scrittura per avere conteggi coerenti."
                                                   Foreground="#6A7B80"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <DataGrid Grid.Row="2"
                                              Margin="0,16,0,0"
                                              ItemsSource="{Binding ContabilitaSupportiItems}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              RowHeaderWidth="0"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Nominativo"
                                                                Width="220"
                                                                Binding="{Binding Nominativo}" />
                                            <DataGridTextColumn Header="Qualifica / ruolo"
                                                                Width="200"
                                                                Binding="{Binding QualificaConRuolo}" />
                                            <DataGridTextColumn Header="Giornate"
                                                                Width="90"
                                                                Binding="{Binding GiornateImpiego}" />
                                            <DataGridTextColumn Header="Trentesimi"
                                                                Width="90"
                                                                Binding="{Binding TrentesimiMaturati}" />
                                            <DataGridTextColumn Header="Ultimo servizio"
                                                                Width="120"
                                                                Binding="{Binding UltimaDataServizioDescrizione}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Stampe e report">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Stampe e report"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="#17313E" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="Prima area report realmente operativa: registro immersioni mensile derivato dai servizi salvati, con riepilogo per categoria di registro."
                                           Foreground="#53646A"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2"
                                Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{Binding RegistroImmersioniPeriodoTitolo}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="{Binding RegistroImmersioniStato}"
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="Il registro usa solo immersioni realmente salvate e partecipazioni SMZ presenti nel servizio."
                                               Foreground="#6A7B80"
                                               FontSize="12"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <StackPanel Width="170">
                                        <TextBlock Text="Mese"
                                                   Foreground="#50626A" />
                                        <ComboBox ItemsSource="{Binding ContabilitaMesiDisponibili}"
                                                  SelectedItem="{Binding ContabilitaMeseSelezionato}"
                                                  DisplayMemberPath="Descrizione" />
                                    </StackPanel>

                                    <StackPanel Width="110"
                                                Margin="12,0,0,0">
                                        <TextBlock Text="Anno"
                                                   Foreground="#50626A" />
                                        <ComboBox ItemsSource="{Binding ContabilitaAnniDisponibili}"
                                                  SelectedItem="{Binding ContabilitaAnnoSelezionato}" />
                                    </StackPanel>

                                    <Button Margin="12,20,0,0"
                                            Content="Aggiorna registro"
                                            Command="{Binding ReloadRegistroImmersioniCommand}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="Righe del registro"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="#17313E" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="Dettaglio per immersione e per operatore, con localita, scopo, categoria e dati tecnici realmente registrati."
                                                   Foreground="#53646A"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <UniformGrid Grid.Row="1"
                                                 Margin="0,16,0,0"
                                                 Columns="4">
                                        <Border Margin="0,0,12,0"
                                                Background="#F4F8FB"
                                                CornerRadius="16"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Immersioni"
                                                           Foreground="#6A7B80" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding RegistroImmersioniTotaleImmersioni}"
                                                           FontSize="24"
                                                           FontWeight="SemiBold"
                                                           Foreground="#17313E" />
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="0,0,12,0"
                                                Background="#F4F8FB"
                                                CornerRadius="16"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Righe operatore"
                                                           Foreground="#6A7B80" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding RegistroImmersioniTotaleRighe}"
                                                           FontSize="24"
                                                           FontWeight="SemiBold"
                                                           Foreground="#17313E" />
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="0,0,12,0"
                                                Background="#F4F8FB"
                                                CornerRadius="16"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Operatori distinti"
                                                           Foreground="#6A7B80" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding RegistroImmersioniTotaleOperatori}"
                                                           FontSize="24"
                                                           FontWeight="SemiBold"
                                                           Foreground="#17313E" />
                                            </StackPanel>
                                        </Border>

                                        <Border Background="#F4F8FB"
                                                CornerRadius="16"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Ore totali"
                                                           Foreground="#6A7B80" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding RegistroImmersioniTotaleOreDisplay}"
                                                           FontSize="24"
                                                           FontWeight="SemiBold"
                                                           Foreground="#17313E" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <DataGrid Grid.Row="2"
                                              Margin="0,18,0,0"
                                              ItemsSource="{Binding RegistroImmersioniItems}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              RowHeaderWidth="0"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Data"
                                                                Width="75"
                                                                Binding="{Binding DataServizioDescrizione}" />
                                            <DataGridTextColumn Header="Ordine"
                                                                Width="85"
                                                                Binding="{Binding NumeroOrdineServizio}" />
                                            <DataGridTextColumn Header="Imm."
                                                                Width="50"
                                                                Binding="{Binding NumeroImmersione}" />
                                            <DataGridTextColumn Header="Orario"
                                                                Width="85"
                                                                Binding="{Binding OrarioDisplay}" />
                                            <DataGridTextColumn Header="Localita"
                                                                Width="0.9*"
                                                                Binding="{Binding Localita}">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap" />
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Scopo"
                                                                Width="1.2*"
                                                                Binding="{Binding ScopoImmersione}">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap" />
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Categoria"
                                                                Width="1.1*"
                                                                Binding="{Binding CategoriaRegistro}">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap" />
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="PerID"
                                                                Width="60"
                                                                Binding="{Binding PerId}" />
                                            <DataGridTextColumn Header="Qual."
                                                                Width="85"
                                                                Binding="{Binding Qualifica}" />
                                            <DataGridTextColumn Header="Nominativo"
                                                                Width="1*"
                                                                Binding="{Binding Nominativo}">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap" />
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="App."
                                                                Width="75"
                                                                Binding="{Binding Apparato}" />
                                            <DataGridTextColumn Header="Prof."
                                                                Width="70"
                                                                Binding="{Binding ProfonditaDisplay}" />
                                            <DataGridTextColumn Header="Fasc."
                                                                Width="55"
                                                                Binding="{Binding FasciaProfondita}" />
                                            <DataGridTextColumn Header="Ore"
                                                                Width="55"
                                                                Binding="{Binding OreImmersioneDisplay}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2"
                                    Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Riepilogo per categoria"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />

                                    <TextBlock Grid.Row="1"
                                               Margin="0,10,0,0"
                                               Text="{Binding RegistroImmersioniCategorieStato}"
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />

                                    <DataGrid Grid.Row="2"
                                              Margin="0,16,0,0"
                                              ItemsSource="{Binding RegistroImmersioniCategorieItems}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              RowHeaderWidth="0"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              MaxHeight="220">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Categoria"
                                                                Width="*"
                                                                Binding="{Binding CategoriaRegistro}" />
                                            <DataGridTextColumn Header="Immersioni"
                                                                Width="90"
                                                                Binding="{Binding ImmersioniTotali}" />
                                            <DataGridTextColumn Header="Righe"
                                                                Width="80"
                                                                Binding="{Binding RigheOperatoreTotali}" />
                                            <DataGridTextColumn Header="Ore"
                                                                Width="75"
                                                                Binding="{Binding OreTotaliDisplay}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </ScrollViewer>

        <Border Grid.Row="2"
                Margin="0,18,0,0"
                Background="#DDE7E2"
                CornerRadius="18"
                Padding="14,10">
            <TextBlock Text="{Binding Stato}"
                       Foreground="#17313E"
                       FontSize="14" />
        </Border>
    </Grid>
</Window>
