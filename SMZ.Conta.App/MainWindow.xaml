                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding GruppoOperativo.Descrizione}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                    <DataTemplate>
                                                        <ComboBox ItemsSource="{Binding DataContext.GruppiOperativiCatalogo, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding GruppoOperativo, UpdateSourceTrigger=PropertyChanged}"
                                                                  DisplayMemberPath="Descrizione" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellEditingTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Ruolo" Width="180">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding RuoloOperativo.Descrizione}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                    <DataTemplate>
                                                        <ComboBox ItemsSource="{Binding DataContext.RuoliOperativiCatalogo, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding RuoloOperativo, UpdateSourceTrigger=PropertyChanged}"
                                                                  DisplayMemberPath="Descrizione" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellEditingTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Contatti"
                                                                Width="220"
                                                                Binding="{Binding Contatti}" />
                                            <DataGridTextColumn Header="Note"
                                                                Width="*"
                                                                Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Scheda personale">
