                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding OrarioInizio}" Value="">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Grid>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="Ora fine" Foreground="#50626A" />
                                                                <Grid Width="120" Margin="0,6,0,0">
                                                                    <TextBox Text="{Binding OrarioFine, UpdateSourceTrigger=PropertyChanged}"
                                                                             MaxLength="5"
                                                                             ToolTip="Digita solo cifre, ad esempio 1015"
                                                                             infra:TimeInputBehavior.AutoFormat="True" />
                                                                    <TextBlock Text="xx:xx"
                                                                               Margin="12,9,0,0"
                                                                               Foreground="#9AAAB5"
                                                                               IsHitTestVisible="False">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding OrarioFine}" Value="">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Grid>
                                                            </StackPanel>
                                                        </Grid>

                                                        <Grid Margin="0,12,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="14" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <StackPanel>
                                                                <TextBlock Text="Direttore immersione" Foreground="#50626A" />
                                                                <ComboBox Margin="0,6,0,0"
                                                                          ItemsSource="{Binding DataContext.OperatoriServizioDisponibili, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          SelectedItem="{Binding DirettoreImmersione}"
                                                                          DisplayMemberPath="NominativoConQualifica" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="Operatore soccorso" Foreground="#50626A" />
                                                                <ComboBox Margin="0,6,0,0"
                                                                          ItemsSource="{Binding DataContext.OperatoriServizioDisponibili, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          SelectedItem="{Binding OperatoreSoccorso}"
                                                                          DisplayMemberPath="NominativoConQualifica" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                                                <TextBlock Text="Assistenza BLSD" Foreground="#50626A" />
                                                                <ComboBox Margin="0,6,0,0"
                                                                          ItemsSource="{Binding DataContext.OperatoriServizioDisponibili, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          SelectedItem="{Binding AssistenteBlsd}"
                                                                          DisplayMemberPath="NominativoConQualifica" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,10,0,0">
                                                                <TextBlock Text="Assistenza sanitaria" Foreground="#50626A" />
                                                                <ComboBox Margin="0,6,0,0"
                                                                          ItemsSource="{Binding DataContext.OperatoriServizioDisponibili, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          SelectedItem="{Binding AssistenteSanitario}"
                                                                          DisplayMemberPath="NominativoConQualifica" />
                                                            </StackPanel>
                                                        </Grid>

                                                        <TextBlock Margin="0,12,0,0"
                                                                   Text="Dettaglio contabile SMZ"
                                                                   Foreground="#17313E"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Text="Compila solo gli operatori SMZ effettivamente entrati in immersione. Fascia, tariffa e importo vengono proposti in automatico."
                                                                   Foreground="#53646A"
                                                                   TextWrapping="Wrap" />

                                                        <DataGrid Margin="0,10,0,0"
                                                                  ItemsSource="{Binding Partecipazioni}"
                                                                  AutoGenerateColumns="False"
                                                                  CanUserAddRows="False"
                                                                  HeadersVisibility="Column"
                                                                  RowHeaderWidth="0"
                                                                  MinHeight="180"
                                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                            <DataGrid.Columns>
                                                                <DataGridCheckBoxColumn Header="In"
                                                                                        Width="42"
                                                                                        Binding="{Binding InImmersione, UpdateSourceTrigger=PropertyChanged}" />
                                                                <DataGridTextColumn Header="Operatore"
                                                                                    Width="170"
                                                                                    Binding="{Binding NominativoConQualifica}" />
                                                                <DataGridTemplateColumn Header="Apparato"
                                                                                        Width="120">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <ComboBox ItemsSource="{Binding DataContext.TipologieImmersioneOperativeCatalogo, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                      SelectedItem="{Binding TipologiaImmersioneOperativa, UpdateSourceTrigger=PropertyChanged}"
                                                                                      DisplayMemberPath="Descrizione" />
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTemplateColumn Header="Prof."
                                                                                        Width="68">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <TextBox Text="{Binding ProfonditaMetri, UpdateSourceTrigger=PropertyChanged}" />
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTemplateColumn Header="Fascia"
                                                                                        Width="88">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <ComboBox ItemsSource="{Binding DataContext.FasceProfonditaCatalogo, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                      SelectedItem="{Binding FasciaProfondita, UpdateSourceTrigger=PropertyChanged}"
                                                                                      DisplayMemberPath="Descrizione" />
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTemplateColumn Header="Ore"
                                                                                        Width="68">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <TextBox Text="{Binding OreImmersione, UpdateSourceTrigger=PropertyChanged}" />
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTemplateColumn Header="Cat."
                                                                                        Width="96">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <ComboBox ItemsSource="{Binding DataContext.CategorieContabiliOreCatalogo, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                      SelectedItem="{Binding CategoriaContabileOre, UpdateSourceTrigger=PropertyChanged}"
                                                                                      DisplayMemberPath="Descrizione" />
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTextColumn Header="Tariffa"
                                                                                    Width="72"
                                                                                    Binding="{Binding TariffaPropostaDisplay}" />
                                                                <DataGridTextColumn Header="Importo"
                                                                                    Width="78"
                                                                                    Binding="{Binding ImportoStimatoDisplay}" />
                                                                <DataGridTemplateColumn Header="Note"
                                                                                        Width="150">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" />
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                            </DataGrid.Columns>
                                                        </DataGrid>

                                                        <TextBlock Margin="0,10,0,0" Text="Note immersione" Foreground="#50626A" />
                                                        <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                                                 TextWrapping="Wrap"
                                                                 AcceptsReturn="True"
                                                                 MinHeight="44" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Scheda personale">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
