                                                    <TextBlock Margin="0,2,0,0"
                                                               Text="{Binding CodiceFiscale}"
                                                               Foreground="#53646A" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Text="{Binding DataArchiviazioneLabel}"
                                                               Foreground="#6A7B80"
                                                               FontSize="12" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="{Binding ArchivioTitolo}"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Foreground="#17313E" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding ArchivioPerId}"
                                                   Foreground="#53646A" />
                                    </StackPanel>

                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="Ripristina scheda"
                                                Command="{Binding RestoreArchivioCommand}" />
                                        <Button Content="Elimina in modo definitivo"
                                                Command="{Binding DeleteArchivioDefinitivoCommand}"
                                                Style="{StaticResource DangerButtonStyle}" />
                                    </StackPanel>
                                </DockPanel>

                                <TextBlock Grid.Row="1"
                                           Margin="0,12,0,0"
                                           Text="Ripristina per riportare la scheda tra i dipendenti attivi. Usa l'eliminazione definitiva solo quando non serve piu alcun recupero."
                                           Foreground="#53646A"
                                           TextWrapping="Wrap" />

                                <Grid Grid.Row="2" Margin="0,18,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="16" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="16" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Border Background="#EEF4EE"
                                            CornerRadius="18"
                                            Padding="16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.2*" />
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Dettaglio archivio"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="#17313E" />
                                                <TextBlock Margin="0,12,0,0"
                                                           Text="{Binding ArchivioCodiceFiscale}"
                                                           Foreground="#17313E"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding ArchivioContatti}"
                                                           Foreground="#53646A"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding ArchivioDataArchiviazione}"
                                                           Foreground="#6A7B80" />
                                            </StackPanel>

                                            <Grid Grid.Column="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Background="#17313E"
                                                        CornerRadius="16"
                                                        Padding="12">
                                                    <StackPanel>
                                                        <TextBlock Text="Abilitazioni"
                                                                   Foreground="#C9D7DA"
                                                                   FontSize="13" />
                                                        <TextBlock Text="{Binding ArchivioAbilitazioniTotali}"
                                                                   Foreground="#FFF8EE"
                                                                   FontSize="24"
                                                                   FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="2"
                                                        Background="#DFE8F1"
                                                        CornerRadius="16"
                                                        Padding="12">
                                                    <StackPanel>
                                                        <TextBlock Text="Visite mediche"
                                                                   Foreground="#53646A"
                                                                   FontSize="13" />
                                                        <TextBlock Text="{Binding ArchivioVisiteTotali}"
                                                                   Foreground="#17313E"
                                                                   FontSize="24"
                                                                   FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="2"
                                            Background="#FFFCF7"
                                            CornerRadius="18"
                                            Padding="16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="Anagrafica archiviata"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="#17313E" />
                                            <TextBlock Grid.Row="1"
                                                       Margin="0,10,0,0"
                                                       Text="{Binding ArchivioAnagraficaSintesi}"
                                                       Foreground="#53646A"
                                                       TextWrapping="Wrap" />

                                            <DataGrid Grid.Row="2"
                                                      Margin="0,16,0,0"
                                                      ItemsSource="{Binding ArchivioAbilitazioni}"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      MinHeight="220"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                      HeadersVisibility="Column"
                                                      RowHeaderWidth="0">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Tipo"
                                                                        Width="220"
                                                                        Binding="{Binding TipoDescrizione}" />
                                                    <DataGridTextColumn Header="Categoria"
                                                                        Width="120"
                                                                        Binding="{Binding Categoria}" />
                                                    <DataGridTextColumn Header="Livello"
                                                                        Width="110"
                                                                        Binding="{Binding Livello}" />
                                                    <DataGridTextColumn Header="Profondita"
                                                                        Width="95"
                                                                        Binding="{Binding ProfonditaMetri}" />
                                                    <DataGridTextColumn Header="Conseguimento"
                                                                        Width="120"
                                                                        Binding="{Binding DataConseguimento}" />
                                                    <DataGridTextColumn Header="Scadenza"
                                                                        Width="120"
                                                                        Binding="{Binding DataScadenza}" />
                                                    <DataGridTextColumn Header="Note"
                                                                        Width="*"
                                                                        Binding="{Binding Note}" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="4"
                                            Background="#FFFCF7"
                                            CornerRadius="18"
                                            Padding="16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="Visite mediche archiviate"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="#17313E" />

                                            <DataGrid Grid.Row="1"
                                                      Margin="0,16,0,0"
                                                      ItemsSource="{Binding ArchivioVisiteMediche}"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      MinHeight="220"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                      HeadersVisibility="Column"
                                                      RowHeaderWidth="0">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Tipo visita"
                                                                        Width="280"
                                                                        Binding="{Binding TipoVisita}" />
                                                    <DataGridTextColumn Header="Ultima visita"
                                                                        Width="130"
                                                                        Binding="{Binding DataUltimaVisita}" />
                                                    <DataGridTextColumn Header="Scadenza"
                                                                        Width="150"
                                                                        Binding="{Binding DataScadenza}" />
                                                    <DataGridTextColumn Header="Esito"
                                                                        Width="150"
                                                                        Binding="{Binding Esito}" />
                                                    <DataGridTextColumn Header="Note"
                                                                        Width="*"
                                                                        Binding="{Binding Note}" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </ScrollViewer>

        <Border Grid.Row="2"
                Margin="0,18,0,0"
                Background="#DDE7E2"
                CornerRadius="18"
                Padding="14,10">
            <TextBlock Text="{Binding Stato}"
                       Foreground="#17313E"
                       FontSize="14" />
        </Border>
    </Grid>
</Window>
