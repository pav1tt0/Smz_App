                                                        <Button Content="{Binding AzioneAbilitazioneLabel}"
                                                                Command="{Binding SaveAbilitazioneCommand}" />
                                                        <Button Content="Pulisci editor"
                                                                Command="{Binding ClearAbilitazioneEditorCommand}"
                                                                Style="{StaticResource SecondaryButtonStyle}" />
                                                        <Button Content="Rimuovi selezionata"
                                                                Command="{Binding RemoveAbilitazioneCommand}"
                                                                Style="{StaticResource DangerButtonStyle}" />
