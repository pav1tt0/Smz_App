                                                                   Foreground="#17313E"
                                                                   FontSize="24"
                                                                   FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="2"
                                            Background="#FFFCF7"
                                            CornerRadius="18"
                                            Padding="16">
