                                            CornerRadius="18"
                                            Padding="16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="Visite mediche archiviate"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="#17313E" />

