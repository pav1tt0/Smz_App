                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#17313E" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SchedaHaScadute}" Value="True">
                                                                    <Setter Property="Foreground" Value="#8B2E2E" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding SchedaScaduteDettaglio}"
                                                           TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#52656B" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SchedaHaScadute}" Value="True">
                                                                    <Setter Property="Foreground" Value="#8B2E2E" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Margin="0,18,0,0"
                                        Background="#F2F5F8"
                                        CornerRadius="18"
                                        Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="Date: usa valori come 18/03/2026. Le abilitazioni e le visite si inseriscono dal pannello guidato qui sotto, non piu scrivendo direttamente in griglia."
                                                   Foreground="#4A5E64"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="Le schede spostate tra le eliminate escono dalla ricerca operativa ma restano recuperabili fino all'eliminazione definitiva."
                                                   Foreground="#6A7B80"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
