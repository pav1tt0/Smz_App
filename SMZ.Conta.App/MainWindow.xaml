<Window x:Class="SMZ.Conta.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:infra="clr-namespace:SMZ.Conta.App.Infrastructure"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Titolo}"
        Width="1520"
        Height="960"
        MinWidth="1320"
        MinHeight="780"
        WindowState="Maximized"
        Background="#F4F4EF"
        FontFamily="Bahnschrift">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFCF7"/>
            <Setter Property="BorderBrush" Value="#D8E1E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#C9D5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="DateTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="150"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#E6EDF5"/>
            <Setter Property="BorderBrush" Value="#CFDAE5"/>
            <Setter Property="Foreground" Value="#4B6175"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12,12,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#F0F5FA"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#143A63"/>
                                <Setter TargetName="TabBorder" Property="Background" Value="#FFFCF7"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#C9D8E7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TabBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="MinWidth" Value="132"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#174E78"/>
            <Setter Property="Foreground" Value="#FFFDF7"/>
            <Setter Property="BorderBrush" Value="#174E78"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.48"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}" />

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#DFE8F1"/>
            <Setter Property="BorderBrush" Value="#DFE8F1"/>
            <Setter Property="Foreground" Value="#17313E"/>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#CFA032"/>
            <Setter Property="BorderBrush" Value="#CFA032"/>
            <Setter Property="Foreground" Value="#17313E"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#8F3434"/>
            <Setter Property="BorderBrush" Value="#8F3434"/>
            <Setter Property="Foreground" Value="#FFF7F3"/>
        </Style>

        <ImageBrush x:Key="HomePhotoBrush"
                    ImageSource="Assets/smz.jpg"
                    Stretch="UniformToFill" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0E68B2" CornerRadius="28" Padding="28" Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="{Binding Titolo}"
                           FontSize="32"
                           FontWeight="SemiBold"
                           Foreground="#FFF7EC" />
                <TextBlock Margin="0,8,0,0"
                           Text="{Binding Sottotitolo}"
                           FontSize="15"
                           Foreground="#CBDBE0" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <TabControl SelectedIndex="{Binding SezioneAttivaIndex}"
                        Background="Transparent"
                        BorderThickness="0">
                <TabItem Header="Home">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                CornerRadius="28"
                                Padding="28">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#143A63" Offset="0" />
                                    <GradientStop Color="#0F6DB5" Offset="0.55" />
                                    <GradientStop Color="#C59B32" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="0.9*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <Border Width="132"
                                            Padding="10,6"
                                            Background="#F7E5B6"
                                            CornerRadius="999"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="SMZ OPERATIVO"
                                                   Foreground="#17313E"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" />
                                    </Border>

                                    <TextBlock Margin="0,18,0,0"
                                               Text="{Binding HomeTitolo}"
                                               FontSize="34"
                                               FontWeight="SemiBold"
                                               Foreground="#FFF8EE" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="{Binding HomeSottotitolo}"
                                               FontSize="16"
                                               Foreground="#D6E2EA"
                                               TextWrapping="Wrap" />

                                    <WrapPanel Margin="0,24,0,0">
                                        <Button Content="Ricerca personale"
                                                Command="{Binding NavigateSectionCommand}"
                                                CommandParameter="1"
                                                Style="{StaticResource AccentButtonStyle}" />
                                        <Button Content="Servizio giornaliero"
                                                Command="{Binding NavigateSectionCommand}"
                                                CommandParameter="2" />
                                        <Button Content="Scheda personale"
                                                Command="{Binding NavigateSectionCommand}"
                                                CommandParameter="3"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                        <Button Content="Archivio"
                                                Command="{Binding NavigateSectionCommand}"
                                                CommandParameter="4"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </WrapPanel>
                                </StackPanel>

                                    <Grid Grid.Column="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="14" />
                                            <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border CornerRadius="24"
                                            Padding="18"
                                            Background="#1A2430">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <DockPanel LastChildFill="False">
                                                <Border DockPanel.Dock="Left"
                                                        Width="84"
                                                        Height="84"
                                                        Background="#F2F5F8"
                                                        CornerRadius="22"
                                                        Padding="10">
                                                    <Image Source="Assets/logo_smz.png"
                                                           Stretch="Uniform" />
                                                </Border>
                                                <StackPanel Margin="14,0,0,0">
                                                    <TextBlock Text="Identita visiva SMZ"
                                                               Foreground="#FFF8EE"
                                                               FontSize="18"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="Home collegata al logo ufficiale e a una foto reale del reparto."
                                                               Foreground="#B8C7D1"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </DockPanel>

                                            <Grid Grid.Row="1" Margin="0,18,0,0">
                                                <Border Background="#274E73"
                                                        CornerRadius="20"
                                                        Margin="0,18,70,0"
                                                        Opacity="0.55" />
                                                <Border Background="#F7E5B6"
                                                        CornerRadius="20"
                                                        Margin="120,44,0,0"
                                                        Opacity="0.75" />
                                                <Border CornerRadius="18"
                                                        Margin="36,0,36,18"
                                                        BorderBrush="#FFFFFF"
                                                        BorderThickness="1.5"
                                                        Background="{StaticResource HomePhotoBrush}">
                                                    <Grid>
                                                        <Rectangle RadiusX="18"
                                                                   RadiusY="18"
                                                                   Fill="#440C1B29" />
                                                        <StackPanel VerticalAlignment="Bottom"
                                                                    Margin="18">
                                                            <TextBlock Text="Nucleo Sommozzatori"
                                                                       Foreground="#FFF8EE"
                                                                       FontSize="22"
                                                                       FontWeight="SemiBold" />
                                                            <TextBlock Margin="0,8,0,0"
                                                                       Text="Interfaccia iniziale aggiornata con logo e immagine reale del reparto."
                                                                       Foreground="#E2EAF0"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Background="#F7F9FB"
                                                CornerRadius="18"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Dipendenti"
                                                           Foreground="#53646A"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding DashboardDipendentiTotali}"
                                                           Foreground="#17313E"
                                                           FontSize="28"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2"
                                                Background="#FBEAEA"
                                                CornerRadius="18"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Scadenze"
                                                           Foreground="#8B2E2E"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding DashboardScadenzeAperte}"
                                                           Foreground="#8B2E2E"
                                                           FontSize="28"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="4"
                                                Background="#EEF4F8"
                                                CornerRadius="18"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Cataloghi servizi"
                                                           Foreground="#53646A"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding DashboardCataloghiServizioTotali}"
                                                           Foreground="#17313E"
                                                           FontSize="28"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1.2*" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Moduli principali"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="L'app si apre ora su una pagina iniziale piu istituzionale. Da qui entri subito nei blocchi di lavoro."
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />

                                    <Border Margin="0,16,0,0"
                                            Background="#F2F5F8"
                                            CornerRadius="18"
                                            Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="Ricerca personale"
                                                       Foreground="#17313E"
                                                       FontSize="17"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="Accesso rapido a nominativi, filtri e scadenziario operativo."
                                                       Foreground="#53646A"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,12,0,0"
                                            Background="#F2F5F8"
                                            CornerRadius="18"
                                            Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="Servizio giornaliero"
                                                       Foreground="#17313E"
                                                       FontSize="17"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="Nuovo modulo per costruire il flusso di registro e contabilita partendo dai servizi del giorno."
                                                       Foreground="#53646A"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,12,0,0"
                                            Background="#F2F5F8"
                                            CornerRadius="18"
                                            Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="Scheda personale e archivio"
                                                       Foreground="#17313E"
                                                       FontSize="17"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="Anagrafica, abilitazioni, visite, stato operativo e recupero storico."
                                                       Foreground="#53646A"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource CardStyle}"
                                    Background="#173A57">
                                <StackPanel>
                                    <TextBlock Text="Prossimi passi"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#FFF8EE" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="Questa home e gia pronta per ospitare identita visiva e accessi rapidi. Le prossime evoluzioni naturali sono:"
                                               Foreground="#D6E2EA"
                                               TextWrapping="Wrap" />

                                    <Border Margin="0,16,0,0"
                                            Background="#254F74"
                                            CornerRadius="18"
                                            Padding="16">
                                        <TextBlock Text="1. Collegare il salvataggio del servizio giornaliero al database."
                                                   Foreground="#FFF8EE"
                                                   TextWrapping="Wrap" />
                                    </Border>

                                    <Border Margin="0,12,0,0"
                                            Background="#254F74"
                                            CornerRadius="18"
                                            Padding="16">
                                        <TextBlock Text="2. Generare il registro immersioni mensile dai servizi salvati."
                                                   Foreground="#FFF8EE"
                                                   TextWrapping="Wrap" />
                                    </Border>

                                    <Border Margin="0,12,0,0"
                                            Background="#254F74"
                                            CornerRadius="18"
                                            Padding="16">
                                        <TextBlock Text="3. Sostituire i placeholder con logo ufficiale e foto reali del reparto."
                                                   Foreground="#FFF8EE"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Ricerca">
                    <Grid Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="390" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Ricerca personale"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />

                                    <TextBlock Margin="0,14,0,0" Text="Cognome o nome" Foreground="#50626A" />
                                    <TextBox Text="{Binding FiltroCognome, UpdateSourceTrigger=PropertyChanged}" />

                                    <Border Margin="0,8,0,0"
                                            Padding="8"
                                            Background="#F4F7F3"
                                            BorderBrush="#D2DBD6"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Visibility="{Binding IsSearchSuggestionsOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ListBox ItemsSource="{Binding SearchSuggestions}"
                                                 SelectedItem="{Binding SelectedSearchSuggestion}"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 MaxHeight="120"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                    </Border>

                                    <TextBlock Margin="0,12,0,0" Text="Abilitazione" Foreground="#50626A" />
                                    <ComboBox ItemsSource="{Binding FiltroAbilitazioni}"
                                              SelectedItem="{Binding FiltroAbilitazione}"
                                              DisplayMemberPath="Descrizione" />

                                    <TextBlock Margin="0,12,0,0" Text="Visite in scadenza entro" Foreground="#50626A" />
                                    <TextBox Text="{Binding FiltroVisiteEntro, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource DateTextBoxStyle}"
                                             MaxLength="10"
                                             ToolTip="Digita 18032026 oppure 18/03/2026"
                                             infra:DateInputBehavior.AutoFormat="True" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="Inserisci una data, ad esempio 18/03/2026"
                                               Foreground="#6A7B80"
                                               FontSize="12" />

                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                        <Button Content="Cerca" Command="{Binding SearchCommand}" />
                                        <Button Content="Pulisci"
                                                Command="{Binding ClearFiltersCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Background="#EEF4F8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="{Binding ScadenzeTitolo}"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Foreground="#17313E"
                                                   TextWrapping="Wrap" />
                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Mostra"
                                                       Foreground="#53646A"
                                                       VerticalAlignment="Center" />
                                            <ComboBox Width="170"
                                                      Margin="10,0,0,0"
                                                      ItemsSource="{Binding FiltriScadenze}"
                                                      SelectedItem="{Binding FiltroScadenzeSelezionato}" />
                                        </StackPanel>
                                    </DockPanel>

                                    <Grid Grid.Row="1" Margin="0,14,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Background="#183E5F" CornerRadius="16" Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="Totali"
                                                           Foreground="#C9D7DA"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding ScadenzeTotali}"
                                                           Foreground="#FFF8EE"
                                                           FontSize="24"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Background="#9C3636" CornerRadius="16" Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="Scadute"
                                                           Foreground="#F8DBDB"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding ScadenzeScadute}"
                                                           Foreground="#FFF7F3"
                                                           FontSize="24"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="4" Background="#CFA032" CornerRadius="16" Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="Urgenti 7 gg"
                                                           Foreground="#664B12"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding ScadenzeUrgenti}"
                                                           Foreground="#17313E"
                                                           FontSize="24"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <ScrollViewer Grid.Row="2"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  MaxHeight="420">
                                        <ItemsControl ItemsSource="{Binding ScadenzeProssime}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Margin="0,0,0,10"
                                                            Padding="0"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            Command="{Binding DataContext.OpenScadenzaCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <ContentPresenter />
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                        <Border Padding="12"
                                                                CornerRadius="16"
                                                                Background="{Binding CardBackground}">
                                                            <StackPanel>
                                                                <DockPanel LastChildFill="False">
                                                                    <TextBlock DockPanel.Dock="Left"
                                                                               Text="{Binding Nominativo}"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="#17313E" />
                                                                    <Border DockPanel.Dock="Right"
                                                                            Background="{Binding BadgeBackground}"
                                                                            CornerRadius="999"
                                                                            Padding="8,3">
                                                                        <TextBlock Text="{Binding GiorniResidui}"
                                                                                   Foreground="{Binding BadgeForeground}"
                                                                                   FontSize="12" />
                                                                    </Border>
                                                                </DockPanel>
                                                                <TextBlock Margin="0,2,0,0"
                                                                           Text="{Binding PerId, StringFormat=PerID {0}}"
                                                                           Foreground="#6B7E82"
                                                                           FontSize="12" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding Titolo}"
                                                                           Foreground="{Binding TitoloForeground}"
                                                                           FontWeight="SemiBold" />
                                                                <TextBlock Margin="0,2,0,0"
                                                                           Text="{Binding StatoSintesi}"
                                                                           Foreground="{Binding TitoloForeground}"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold" />
                                                                <TextBlock Margin="0,2,0,0"
                                                                           Text="{Binding Origine}"
                                                                           Foreground="#6B7E82"
                                                                           FontSize="12" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding DataScadenza}"
                                                                           Foreground="#17313E" />
                                                                <TextBlock Margin="0,2,0,0"
                                                                           Text="{Binding Dettaglio}"
                                                                           Foreground="#607176"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Border>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="Elenco dipendenti"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <Button DockPanel.Dock="Right"
                                            Content="Apri scheda"
                                            Command="{Binding OpenSelectedPersonaleCommand}" />
                                </DockPanel>

                                <TextBlock Grid.Row="1"
                                           Margin="0,12,0,0"
                                           Text="Seleziona un nominativo per caricare la scheda completa e passare alla modifica."
                                           Foreground="#53646A"
                                           TextWrapping="Wrap" />

                                <ListBox Grid.Row="2"
                                         Margin="0,16,0,0"
                                         ItemsSource="{Binding PersonaleItems}"
                                         SelectedItem="{Binding SelectedPersonale}"
                                         MaxHeight="640"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.CanContentScroll="False"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         MinHeight="640">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0,0,12,12" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="260"
                                                    MinHeight="96"
                                                    Padding="14"
                                                    Background="#F7F9FB"
                                                    BorderBrush="#DCE5EC"
                                                    BorderThickness="1"
                                                    CornerRadius="16">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Nominativo}"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               Foreground="#17313E" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Text="{Binding CodiceFiscale}"
                                                               Foreground="#53646A" />
                                                    <TextBlock Margin="0,2,0,0"
                                                               Text="{Binding Contatti}"
                                                               Foreground="#53646A" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Servizio giornaliero">
                    <Grid Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="380" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Bozza modulo servizi"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="{Binding ServizioBozzaStato}"
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />

                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                        <Button Content="Nuovo servizio"
                                                Command="{Binding NewServizioCommand}" />
                                        <Button Content="Aggiorna personale"
                                                Command="{Binding ReloadServizioPersonaleCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,12,0,0"
                                    Style="{StaticResource CardStyle}"
                                    Background="#EEF4F8">
                                <StackPanel>
                                    <TextBlock Text="Sintesi operativa"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Background="#173A57"
                                                CornerRadius="16"
                                                Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="Partecipanti"
                                                           Foreground="#C9D7DA"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding ServizioPartecipantiTotali}"
                                                           Foreground="#FFF8EE"
                                                           FontSize="24"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2"
                                                Background="#CFA032"
                                                CornerRadius="16"
                                                Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="Presenti"
                                                           Foreground="#664B12"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding ServizioPresentiTotali}"
                                                           Foreground="#17313E"
                                                           FontSize="24"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Margin="0,10,0,0"
                                            Background="#F8FBFD"
                                            CornerRadius="16"
                                            Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Categoria registro"
                                                       Foreground="#53646A"
                                                       FontSize="12" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding ServizioCategoriaRegistroDescrizione}"
                                                       Foreground="#17313E"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,10,0,0"
                                            Background="#F8FBFD"
                                            CornerRadius="16"
                                            Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Tipo servizio"
                                                       Foreground="#53646A"
                                                       FontSize="12" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding ServizioTipoDescrizione}"
                                                       Foreground="#17313E"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding ServizioFuoriSedeDescrizione}"
                                                       Foreground="#53646A" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding ServizioImmersioniCompilate, StringFormat=Immersioni compilate: {0}/2}"
                                                       Foreground="#53646A" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <TextBlock Text="Servizio giornaliero"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="Prima schermata operativa del nuovo modulo. In questa fase puoi impostare la bozza del servizio, le immersioni e i partecipanti; il salvataggio definitivo verra collegato nel passo successivo."
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />

                                    <Border Margin="0,18,0,0"
                                            Background="#F2F5F8"
                                            CornerRadius="18"
                                            Padding="16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="170" />
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Data servizio" Foreground="#50626A" />
                                                <TextBox Text="{Binding ServizioData, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource DateTextBoxStyle}"
                                                         MaxLength="10"
                                                         ToolTip="Digita 25032026 oppure 25/03/2026"
                                                         infra:DateInputBehavior.AutoFormat="True" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Tipo servizio" Foreground="#50626A" />
                                                <ComboBox ItemsSource="{Binding TipiServizioDisponibili}"
                                                          SelectedItem="{Binding ServizioTipoSelezionato}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="Localita" Foreground="#50626A" />
                                                <ComboBox ItemsSource="{Binding LocalitaOperativeCatalogo}"
                                                          SelectedItem="{Binding ServizioLocalitaSelezionata}"
                                                          DisplayMemberPath="Descrizione" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                                <TextBlock Text="Unita navale" Foreground="#50626A" />
                                                <ComboBox ItemsSource="{Binding UnitaNavaliCatalogo}"
                                                          SelectedItem="{Binding ServizioUnitaNavaleSelezionata}"
                                                          DisplayMemberPath="Descrizione" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,10,0,0">
                                                <TextBlock Text="Fuori sede" Foreground="#50626A" />
                                                <CheckBox Margin="0,10,0,0"
                                                          IsChecked="{Binding ServizioFuoriSede}"
                                                          Content="Applica indennita fuori sede" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.Column="4" Margin="0,10,0,0">
                                                <TextBlock Text="Scopo immersione" Foreground="#50626A" />
                                                <ComboBox ItemsSource="{Binding ScopiImmersioneCatalogo}"
                                                          SelectedItem="{Binding ServizioScopoSelezionato}"
                                                          DisplayMemberPath="Descrizione" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" Grid.ColumnSpan="5" Margin="0,10,0,0">
                                                <TextBlock Text="Attivita svolta" Foreground="#50626A" />
                                                <TextBox Text="{Binding ServizioAttivitaSvolta, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap"
                                                         AcceptsReturn="True"
                                                         MinHeight="64" />
                                                <TextBlock Margin="0,10,0,0" Text="Note servizio" Foreground="#50626A" />
                                                <TextBox Text="{Binding ServizioNote, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap"
                                                         AcceptsReturn="True"
                                                         MinHeight="54" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <ItemsControl Margin="0,18,0,0"
                                                  ItemsSource="{Binding ServizioImmersioniBozza}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="520"
                                                        Margin="0,0,16,16"
                                                        Background="#F8FBFD"
                                                        BorderBrush="#D8E1E8"
                                                        BorderThickness="1"
                                                        CornerRadius="18"
                                                        Padding="16">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding NumeroImmersione, StringFormat=Immersione {0}}"
                                                                   FontSize="18"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#17313E" />

                                                        <Grid Margin="0,12,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="16" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel>
                                                                <TextBlock Text="Ora inizio" Foreground="#50626A" />
                                                                <TextBox Text="{Binding OrarioInizio, UpdateSourceTrigger=PropertyChanged}"
                                                                         Width="120"
                                                                         ToolTip="Formato consigliato: 08:30" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="Ora fine" Foreground="#50626A" />
                                                                <TextBox Text="{Binding OrarioFine, UpdateSourceTrigger=PropertyChanged}"
                                                                         Width="120"
                                                                         ToolTip="Formato consigliato: 10:15" />
                                                            </StackPanel>
                                                        </Grid>

                                                        <TextBlock Margin="0,10,0,0" Text="Direttore immersione" Foreground="#50626A" />
                                                        <ComboBox ItemsSource="{Binding DataContext.OperatoriServizioDisponibili, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding DirettoreImmersione}"
                                                                  DisplayMemberPath="NominativoConQualifica" />

                                                        <TextBlock Margin="0,10,0,0" Text="Operatore soccorso" Foreground="#50626A" />
                                                        <ComboBox ItemsSource="{Binding DataContext.OperatoriServizioDisponibili, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding OperatoreSoccorso}"
                                                                  DisplayMemberPath="NominativoConQualifica" />

                                                        <TextBlock Margin="0,10,0,0" Text="Assistenza BLSD" Foreground="#50626A" />
                                                        <ComboBox ItemsSource="{Binding DataContext.OperatoriServizioDisponibili, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding AssistenteBlsd}"
                                                                  DisplayMemberPath="NominativoConQualifica" />

                                                        <TextBlock Margin="0,10,0,0" Text="Assistenza sanitaria" Foreground="#50626A" />
                                                        <ComboBox ItemsSource="{Binding DataContext.OperatoriServizioDisponibili, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding AssistenteSanitario}"
                                                                  DisplayMemberPath="NominativoConQualifica" />

                                                        <TextBlock Margin="0,10,0,0" Text="Note immersione" Foreground="#50626A" />
                                                        <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                                                 TextWrapping="Wrap"
                                                                 AcceptsReturn="True"
                                                                 MinHeight="48" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="Personale impiegato"
                                               FontSize="19"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="In questa fase il personale e gestito in una griglia unica: scegli gruppo operativo, presenza e ruolo. E piu flessibile del modello Word e si presta meglio ai conteggi futuri."
                                               Foreground="#53646A"
                                               TextWrapping="Wrap" />

                                    <DataGrid Margin="0,16,0,0"
                                              ItemsSource="{Binding ServizioPartecipantiBozza}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              MinHeight="360"
                                              HeadersVisibility="Column"
                                              RowHeaderWidth="0"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Qualifica"
                                                                Width="120"
                                                                Binding="{Binding Qualifica}" />
                                            <DataGridTextColumn Header="Cognome e nome"
                                                                Width="220"
                                                                Binding="{Binding Nominativo}" />
                                            <DataGridCheckBoxColumn Header="Presente"
                                                                    Width="90"
                                                                    Binding="{Binding Presente, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridTemplateColumn Header="Gruppo operativo" Width="180">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding GruppoOperativo.Descrizione}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                    <DataTemplate>
                                                        <ComboBox ItemsSource="{Binding DataContext.GruppiOperativiCatalogo, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding GruppoOperativo, UpdateSourceTrigger=PropertyChanged}"
                                                                  DisplayMemberPath="Descrizione" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellEditingTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Ruolo" Width="180">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding RuoloOperativo.Descrizione}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                    <DataTemplate>
                                                        <ComboBox ItemsSource="{Binding DataContext.RuoliOperativiCatalogo, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding RuoloOperativo, UpdateSourceTrigger=PropertyChanged}"
                                                                  DisplayMemberPath="Descrizione" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellEditingTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Contatti"
                                                                Width="220"
                                                                Binding="{Binding Contatti}" />
                                            <DataGridTextColumn Header="Note"
                                                                Width="*"
                                                                Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Scheda personale">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="Scheda anagrafica"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E"
                                               VerticalAlignment="Center" />
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="Nuovo"
                                                Command="{Binding NewCommand}"
                                                Style="{StaticResource AccentButtonStyle}" />
                                        <Button Content="Salva"
                                                Command="{Binding SaveCommand}" />
                                        <Button Content="Archivia"
                                                Command="{Binding DeleteCommand}"
                                                Style="{StaticResource DangerButtonStyle}" />
                                    </StackPanel>
                                </DockPanel>

                                <Border Margin="0,18,0,0"
                                        Background="#173A57"
                                        CornerRadius="22"
                                        Padding="20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.25*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Riepilogo operativo"
                                                       Foreground="#CBDBE0"
                                                       FontSize="13" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding SchedaRiepilogoTitolo}"
                                                       Foreground="#FFF8EE"
                                                       FontSize="22"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding SchedaRiepilogoPerId}"
                                                       Foreground="#D9E4E7" />
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                                Background="#24527B"
                                                CornerRadius="18"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Abilitazioni principali"
                                                           Foreground="#CBDBE0"
                                                           FontSize="12" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding SchedaAbilitazioniPrincipali}"
                                                           Foreground="#FFF8EE"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="{Binding SchedaAbilitazioniPrincipaliFooter}"
                                                           Foreground="#CBDBE0"
                                                           FontSize="12" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="4"
                                                Background="#F4F7F3"
                                                CornerRadius="18"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Prossima scadenza"
                                                           Foreground="#50626A"
                                                           FontSize="12" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding SchedaProssimaScadenza}"
                                                           Foreground="#17313E"
                                                           FontSize="22"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding SchedaProssimaScadenzaDettaglio}"
                                                           Foreground="#52656B"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="6"
                                                CornerRadius="18"
                                                Padding="14">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#EEF2F4" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SchedaHaScadute}" Value="True">
                                                            <Setter Property="Background" Value="#FBEAEA" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="{Binding SchedaScaduteTitolo}"
                                                           FontSize="12">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#53646A" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SchedaHaScadute}" Value="True">
                                                                    <Setter Property="Foreground" Value="#8B2E2E" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding SchedaScaduteHighlight}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#17313E" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SchedaHaScadute}" Value="True">
                                                                    <Setter Property="Foreground" Value="#8B2E2E" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding SchedaScaduteDettaglio}"
                                                           TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#52656B" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SchedaHaScadute}" Value="True">
                                                                    <Setter Property="Foreground" Value="#8B2E2E" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Margin="0,18,0,0"
                                        Background="#F2F5F8"
                                        CornerRadius="18"
                                        Padding="16">
                                    <TextBlock Text="Date: usa valori come 18/03/2026. Le abilitazioni e le visite si inseriscono dal pannello guidato qui sotto, non piu scrivendo direttamente in griglia."
                                               Foreground="#4A5E64"
                                               TextWrapping="Wrap" />
                                </Border>

                                    <TextBlock Margin="0,16,0,0"
                                               Text="Dati di servizio"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#17313E" />
                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="PerID" Foreground="#50626A" />
                                            <TextBox Text="{Binding PerIdInput, UpdateSourceTrigger=PropertyChanged}"
                                                     IsReadOnly="{Binding IsExistingPerson}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Qualifica" Foreground="#50626A" />
                                            <ComboBox ItemsSource="{Binding QualificheDisponibili}"
                                                      Text="{Binding Qualifica, UpdateSourceTrigger=PropertyChanged}"
                                                      IsEditable="True"
                                                      IsTextSearchEnabled="True" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                            <TextBlock Text="Matricola personale" Foreground="#50626A" />
                                            <TextBox Text="{Binding MatricolaPersonale, UpdateSourceTrigger=PropertyChanged}" />
