<UserControl x:Class="SMZ.Conta.App.Controls.DateInputPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="clr-namespace:SMZ.Conta.App.Infrastructure"
             x:Name="Root">
    <UserControl.Resources>
        <Style x:Key="CalendarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,9,6,0" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Background" Value="#EEF3F8" />
            <Setter Property="BorderBrush" Value="#C9D5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#DCE7F1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#CFDDEA" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <TextBox
                 Text="{Binding Text, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="{Binding ToolTip, ElementName=Root}"
                 Padding="10,8,38,8"
                 MaxLength="10"
                 infra:DateInputBehavior.AutoFormat="True" />

        <Button Click="CalendarButton_Click"
                Style="{StaticResource CalendarButtonStyle}"
                ToolTip="{Binding ToolTip, ElementName=Root}">
            <Viewbox Width="14" Height="14">
                <Canvas Width="24" Height="24">
                    <Rectangle Canvas.Left="3.5"
                               Canvas.Top="5.5"
                               Width="17"
                               Height="15"
                               RadiusX="2"
                               RadiusY="2"
                               Stroke="#24445B"
                               StrokeThickness="1.7" />
                    <Line X1="3.5"
                          Y1="9"
                          X2="20.5"
                          Y2="9"
                          Stroke="#24445B"
                          StrokeThickness="1.7" />
                    <Line X1="8"
                          Y1="3.5"
                          X2="8"
                          Y2="7.5"
                          Stroke="#24445B"
                          StrokeThickness="1.7"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" />
                    <Line X1="16"
                          Y1="3.5"
                          X2="16"
                          Y2="7.5"
                          Stroke="#24445B"
                          StrokeThickness="1.7"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" />
                    <Line X1="7"
                          Y1="13"
                          X2="10"
                          Y2="13"
                          Stroke="#24445B"
                          StrokeThickness="1.7"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" />
                    <Line X1="14"
                          Y1="13"
                          X2="17"
                          Y2="13"
                          Stroke="#24445B"
                          StrokeThickness="1.7"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" />
                    <Line X1="7"
                          Y1="16.5"
                          X2="10"
                          Y2="16.5"
                          Stroke="#24445B"
                          StrokeThickness="1.7"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" />
                    <Line X1="14"
                          Y1="16.5"
                          X2="17"
                          Y2="16.5"
                          Stroke="#24445B"
                          StrokeThickness="1.7"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" />
                </Canvas>
            </Viewbox>
        </Button>

        <Popup x:Name="CalendarPopup"
               Placement="Bottom"
               PlacementTarget="{Binding ElementName=Root}"
               StaysOpen="False">
            <Border Margin="0,4,0,0"
                    Background="#FFFCF7"
                    BorderBrush="#C9D5E1"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="8">
                <Calendar x:Name="CalendarHost"
                          SelectedDatesChanged="CalendarHost_SelectedDatesChanged" />
            </Border>
        </Popup>
    </Grid>
</UserControl>
